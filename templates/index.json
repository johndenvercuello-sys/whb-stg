    "custom_liquid_QjjEqz": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Custom liquid",
      "settings": {
        "custom_liquid": "<!-- W Bakehouse Events Section -->\n\n<style>\n/* ===============================\n   W Bakehouse Events Section\n================================ */\n\n.wb-events {\n  background: #f7ecde;\n  padding: 90px 10px;\n  font-family: Arial, Helvetica, sans-serif;\n}\n\n.wb-container {\n  max-width: 1300px;\n  margin: auto;\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 50px;\n  align-items: center;\n}\n\n/* Left Content */\n\n.wb-caption {\n  color: #c96b2c;\n  letter-spacing: 3px;\n  font-size: 13px;\n  font-weight: 600;\n  margin-bottom: 15px;\n}\n\n.wb-title {\n  font-size: 42px;\n  font-weight: 300;\n  line-height: 1.3;\n  color: #1e1e1e;\n  margin-bottom: 25px;\n}\n\n.wb-body {\n  font-size: 16px;\n  line-height: 1.8;\n  color: #222;\n  margin-bottom: 35px;\n  max-width: 500px;\n}\n\n.wb-btn {\n  display: inline-block;\n  padding: 14px 34px;\n  background: #1e1e1e;\n  color: #fff;\n  text-decoration: none;\n  font-size: 14px;\n  letter-spacing: 1px;\n  border-radius: 4px;\n  transition: 0.3s ease;\n}\n\n.wb-btn:hover {\n  background: #c96b2c;\n}\n\n/* Right Image */\n\n.wb-image img {\n  width: 130%;\n  border-radius: 6px;\n  box-shadow: 0 10px 25px rgba(0,0,0,0.15);\n}\n\n/* Mobile */\n\n@media (max-width: 768px) {\n\n  .wb-container {\n    grid-template-columns: 1fr;\n    text-align: center;\n  }\n\n  .wb-body {\n    margin: auto;\n  }\n\n  .wb-title {\n    font-size: 30px;\n  }\n}\n</style>\n\n\n<section class=\"wb-events\">\n\n  <div class=\"wb-container\">\n\n    <!-- Left Content -->\n    <div class=\"wb-content\">\n\n      <p class=\"wb-caption\">\n        BANQUETS & EVENTS\n      </p>\n\n      <h1 class=\"wb-title\">\n        CATERED ARTISANAL<br>\n        SOURDOUGH DELI<br>\n        & PASTRIES\n      </h1>\n\n      <p class=\"wb-body\">\n        Bring the W Bakehouse experience to your private gatherings,\n        celebrations or corporate events. Package options are available,\n        ranging from catered sandwiches and pastries set-up, to a full\n        deli with coffee bar set-up, depending on your event-dining\n        requirements.\n      </p>\n\n      <a href=\"/pages/events-banquets\" class=\"wb-btn\">\n        Contact Us\n      </a>\n\n    </div>\n\n    <!-- Right Image -->\n    <div class=\"wb-image\">\n      <img\n        src=\"https://cdn.shopify.com/s/files/1/0700/2764/0984/files/20260119_161030.jpg?v=1770305865\"\n        alt=\"W Bakehouse Catering\"\n      >\n    </div>\n\n  </div>\n\n</section>",
        "custom_class": ""
      }
    },
