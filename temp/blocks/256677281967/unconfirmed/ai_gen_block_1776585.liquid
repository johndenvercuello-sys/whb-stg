{% doc %}
  @prompt
    cart item
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cart-item-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-cart-item-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.item_spacing }}px;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-cart-item-image-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-cart-item-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cart-item-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-cart-item-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
  }

  .ai-cart-item-details-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-cart-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-cart-item-variant-{{ ai_gen_id }} {
    font-size: {{ block.settings.variant_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0;
  }

  .ai-cart-item-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-item-actions-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
  }

  .ai-cart-item-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    padding: 4px 8px;
  }

  .ai-cart-item-qty-button-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    color: {{ block.settings.text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
  }

  .ai-cart-item-qty-button-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-cart-item-qty-input-{{ ai_gen_id }} {
    width: 40px;
    text-align: center;
    border: none;
    background: transparent;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-item-remove-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    color: {{ block.settings.remove_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-cart-item-remove-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-cart-item-total-{{ ai_gen_id }} {
    flex-shrink: 0;
    text-align: right;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .ai-cart-item-total-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-cart-item-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-cart-item-image-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
    }

    .ai-cart-item-total-{{ ai_gen_id }} {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
{% endstyle %}

<cart-item-{{ ai_gen_id }}
  class="ai-cart-item-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if cart.items.size > 0 %}
    {% assign item = cart.items.first %}
    <div class="ai-cart-item-wrapper-{{ ai_gen_id }}">
      <div class="ai-cart-item-image-{{ ai_gen_id }}">
        {% if item.image %}
          <img
            src="{{ item.image | image_url: width: 200 }}"
            alt="{{ item.image.alt | escape }}"
            loading="lazy"
            width="200"
            height="200"
          >
        {% else %}
          <div class="ai-cart-item-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-cart-item-details-{{ ai_gen_id }}">
        <h3 class="ai-cart-item-title-{{ ai_gen_id }}">{{ item.product.title }}</h3>

        {% if item.variant.title != 'Default Title' %}
          <p class="ai-cart-item-variant-{{ ai_gen_id }}">{{ item.variant.title }}</p>
        {% endif %}

        {% if block.settings.show_vendor and item.vendor != blank %}
          <p class="ai-cart-item-variant-{{ ai_gen_id }}">{{ item.vendor }}</p>
        {% endif %}

        <div class="ai-cart-item-price-{{ ai_gen_id }}">
          {{ item.price | money }}
        </div>

        <div class="ai-cart-item-actions-{{ ai_gen_id }}">
          <div class="ai-cart-item-quantity-{{ ai_gen_id }}">
            <button
              class="ai-cart-item-qty-button-{{ ai_gen_id }}"
              aria-label="Decrease quantity"
              data-action="decrease"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="4" y1="8" x2="12" y2="8"></line>
              </svg>
            </button>
            <input
              type="number"
              class="ai-cart-item-qty-input-{{ ai_gen_id }}"
              value="{{ item.quantity }}"
              min="1"
              aria-label="Quantity"
              readonly
            >
            <button
              class="ai-cart-item-qty-button-{{ ai_gen_id }}"
              aria-label="Increase quantity"
              data-action="increase"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="8" y1="4" x2="8" y2="12"></line>
                <line x1="4" y1="8" x2="12" y2="8"></line>
              </svg>
            </button>
          </div>

          <button
            class="ai-cart-item-remove-{{ ai_gen_id }}"
            aria-label="Remove item"
          >
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="5" x2="15" y2="15"></line>
              <line x1="15" y1="5" x2="5" y2="15"></line>
            </svg>
          </button>
        </div>
      </div>

      <div class="ai-cart-item-total-{{ ai_gen_id }}">
        <div class="ai-cart-item-total-price-{{ ai_gen_id }}">
          {{ item.line_price | money }}
        </div>
      </div>
    </div>
  {% else %}
    <div class="ai-cart-item-wrapper-{{ ai_gen_id }}">
      <div class="ai-cart-item-image-{{ ai_gen_id }}">
        <div class="ai-cart-item-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      </div>

      <div class="ai-cart-item-details-{{ ai_gen_id }}">
        <h3 class="ai-cart-item-title-{{ ai_gen_id }}">Sample Product</h3>
        <p class="ai-cart-item-variant-{{ ai_gen_id }}">Size: Medium / Color: Blue</p>
        <div class="ai-cart-item-price-{{ ai_gen_id }}">₱500.00</div>

        <div class="ai-cart-item-actions-{{ ai_gen_id }}">
          <div class="ai-cart-item-quantity-{{ ai_gen_id }}">
            <button class="ai-cart-item-qty-button-{{ ai_gen_id }}" aria-label="Decrease quantity">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="4" y1="8" x2="12" y2="8"></line>
              </svg>
            </button>
            <input type="number" class="ai-cart-item-qty-input-{{ ai_gen_id }}" value="1" min="1" aria-label="Quantity" readonly>
            <button class="ai-cart-item-qty-button-{{ ai_gen_id }}" aria-label="Increase quantity">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="8" y1="4" x2="8" y2="12"></line>
                <line x1="4" y1="8" x2="12" y2="8"></line>
              </svg>
            </button>
          </div>

          <button class="ai-cart-item-remove-{{ ai_gen_id }}" aria-label="Remove item">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="5" x2="15" y2="15"></line>
              <line x1="15" y1="5" x2="5" y2="15"></line>
            </svg>
          </button>
        </div>
      </div>

      <div class="ai-cart-item-total-{{ ai_gen_id }}">
        <div class="ai-cart-item-total-price-{{ ai_gen_id }}">₱500.00</div>
      </div>
    </div>
  {% endif %}
</cart-item-{{ ai_gen_id }}>

<script>
  (function() {
    class CartItem{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        const decreaseBtn = this.querySelector('[data-action="decrease"]');
        const increaseBtn = this.querySelector('[data-action="increase"]');
        const removeBtn = this.querySelector('.ai-cart-item-remove-{{ ai_gen_id }}');
        const qtyInput = this.querySelector('.ai-cart-item-qty-input-{{ ai_gen_id }}');

        if (decreaseBtn) {
          decreaseBtn.addEventListener('click', () => {
            const currentValue = parseInt(qtyInput.value);
            if (currentValue > 1) {
              qtyInput.value = currentValue - 1;
              this.updateQuantity(currentValue - 1);
            }
          });
        }

        if (increaseBtn) {
          increaseBtn.addEventListener('click', () => {
            const currentValue = parseInt(qtyInput.value);
            qtyInput.value = currentValue + 1;
            this.updateQuantity(currentValue + 1);
          });
        }

        if (removeBtn) {
          removeBtn.addEventListener('click', () => {
            this.removeItem();
          });
        }
      }

      updateQuantity(quantity) {
        console.log('Update quantity to:', quantity);
      }

      removeItem() {
        console.log('Remove item from cart');
      }
    }

    customElements.define('cart-item-{{ ai_gen_id }}', CartItem{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Cart item",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Padding",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Spacing",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Size",
      "min": 60,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "variant_size",
      "label": "Variant size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#eeeeee"
    },
    {
      "type": "color",
      "id": "remove_color",
      "label": "Remove button",
      "default": "#da3f3f"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "label": "Input border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Cart item"
    }
  ]
}
{% endschema %}
