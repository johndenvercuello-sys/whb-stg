{% doc %}
  @prompt
    dynamic cart table with Product item "image and title link to item details page, size, gift options, pickup date, pickup day, countdown timer before automatically remove ", price, quantity, total price. use Montserrat font. add clear cart button and add more products button link to all collections at the bottom. add condition if item is added over 1 hour passed remove item automatically then reload all site session.
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap');

  .ai-cart-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    font-family: 'Montserrat', sans-serif;
    padding: 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-cart-table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    margin-bottom: 30px;
  }

  .ai-cart-table-main-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    min-width: 800px;
  }

  .ai-cart-table-main-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_bg_color }};
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-cart-table-main-{{ ai_gen_id }} th {
    padding: 15px 10px;
    text-align: left;
    font-weight: 600;
    font-size: 14px;
    color: {{ block.settings.header_text_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-cart-table-main-{{ ai_gen_id }} tbody tr {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-cart-table-main-{{ ai_gen_id }} td {
    padding: 20px 10px;
    vertical-align: middle;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-item-product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .ai-cart-item-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .ai-cart-item-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cart-item-details-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-cart-item-title-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 5px;
  }

  .ai-cart-item-title-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
    text-decoration: none;
  }

  .ai-cart-item-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-cart-item-meta-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.subtext_color }};
    margin-top: 5px;
  }

  .ai-cart-item-meta-{{ ai_gen_id }} div {
    margin-bottom: 3px;
  }

  .ai-cart-countdown-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 8px;
    background-color: {{ block.settings.countdown_bg_color }};
    color: {{ block.settings.countdown_text_color }};
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    margin-top: 5px;
  }

  .ai-cart-countdown-{{ ai_gen_id }}.warning {
    background-color: {{ block.settings.countdown_warning_color }};
    color: #ffffff;
  }

  .ai-cart-price-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    width: fit-content;
  }

  .ai-cart-quantity-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 8px 12px;
    cursor: pointer;
    font-size: 18px;
    color: {{ block.settings.text_color }};
    transition: background-color 0.2s;
  }

  .ai-cart-quantity-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.border_color }};
  }

  .ai-cart-quantity-input-{{ ai_gen_id }} {
    width: 50px;
    text-align: center;
    border: none;
    font-weight: 600;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-total-{{ ai_gen_id }} {
    font-weight: 700;
    font-size: 18px;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-actions-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-cart-button-{{ ai_gen_id }} {
    padding: 15px 30px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
  }

  .ai-cart-button-clear-{{ ai_gen_id }} {
    background-color: {{ block.settings.clear_button_bg }};
    color: {{ block.settings.clear_button_text }};
    border: 2px solid {{ block.settings.clear_button_bg }};
  }

  .ai-cart-button-clear-{{ ai_gen_id }}:hover {
    background-color: transparent;
    color: {{ block.settings.clear_button_bg }};
  }

  .ai-cart-button-shop-{{ ai_gen_id }} {
    background-color: {{ block.settings.shop_button_bg }};
    color: {{ block.settings.shop_button_text }};
  }

  .ai-cart-button-shop-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.shop_button_hover_bg }};
  }

  .ai-cart-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
  }

  .ai-cart-empty-{{ ai_gen_id }} h2 {
    font-size: 24px;
    margin-bottom: 15px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-empty-{{ ai_gen_id }} p {
    font-size: 16px;
    color: {{ block.settings.subtext_color }};
    margin-bottom: 25px;
  }

  @media screen and (max-width: 768px) {
    .ai-cart-table-{{ ai_gen_id }} {
      width: 100%;
      padding: 15px;
    }

    .ai-cart-actions-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-cart-button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

<cart-table-{{ ai_gen_id }}
  class="ai-cart-table-{{ ai_gen_id }}"
  data-expiry-hours="{{ block.settings.expiry_hours }}"
  {{ block.shopify_attributes }}
>
  {% if cart.item_count > 0 %}
    <div class="ai-cart-table-wrapper-{{ ai_gen_id }}">
      <table class="ai-cart-table-main-{{ ai_gen_id }}">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr class="ai-cart-row-{{ ai_gen_id }}" data-line-index="{{ forloop.index }}" data-variant-id="{{ item.variant_id }}" data-added-at="{{ item.properties['_added_at'] | default: 'now' }}">
              <td>
                <div class="ai-cart-item-product-{{ ai_gen_id }}">
                  <div class="ai-cart-item-image-{{ ai_gen_id }}">
                    {% if item.image %}
                      <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" loading="lazy">
                    {% else %}
                      <div style="background-color: #f4f4f4; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <div class="ai-cart-item-details-{{ ai_gen_id }}">
                    <div class="ai-cart-item-title-{{ ai_gen_id }}">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </div>
                    <div class="ai-cart-item-meta-{{ ai_gen_id }}">
                      {% if item.variant.title != 'Default Title' %}
                        <div><strong>Size:</strong> {{ item.variant.title }}</div>
                      {% endif %}
                      {% if item.properties['Gift Options'] %}
                        <div><strong>Gift:</strong> {{ item.properties['Gift Options'] }}</div>
                      {% endif %}
                      {% if item.properties['Pickup Date'] %}
                        <div><strong>Pickup Date:</strong> {{ item.properties['Pickup Date'] }}</div>
                      {% endif %}
                      {% if item.properties['Pickup Day'] %}
                        <div><strong>Pickup Day:</strong> {{ item.properties['Pickup Day'] }}</div>
                      {% endif %}
                    </div>
                    <div class="ai-cart-countdown-{{ ai_gen_id }}" data-countdown-element>
                      ⏱️ <span class="countdown-time">Calculating...</span>
                    </div>
                  </div>
                </div>
              </td>
              <td>
                <div class="ai-cart-price-{{ ai_gen_id }}">{{ item.price | money }}</div>
              </td>
              <td>
                <div class="ai-cart-quantity-{{ ai_gen_id }}">
                  <button class="ai-cart-quantity-btn-{{ ai_gen_id }}" data-action="decrease" data-line="{{ forloop.index }}">−</button>
                  <input type="number" class="ai-cart-quantity-input-{{ ai_gen_id }}" value="{{ item.quantity }}" min="1" data-line="{{ forloop.index }}" readonly>
                  <button class="ai-cart-quantity-btn-{{ ai_gen_id }}" data-action="increase" data-line="{{ forloop.index }}">+</button>
                </div>
              </td>
              <td>
                <div class="ai-cart-total-{{ ai_gen_id }}">{{ item.line_price | money }}</div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="ai-cart-actions-{{ ai_gen_id }}">
      <button class="ai-cart-button-{{ ai_gen_id }} ai-cart-button-clear-{{ ai_gen_id }}" data-clear-cart>
        Clear Cart
      </button>
      <a href="/collections/all" class="ai-cart-button-{{ ai_gen_id }} ai-cart-button-shop-{{ ai_gen_id }}">
        Add More Products
      </a>
    </div>
  {% else %}
    <div class="ai-cart-empty-{{ ai_gen_id }}">
      <h2>Your cart is empty</h2>
      <p>Add some products to get started</p>
      <a href="/collections/all" class="ai-cart-button-{{ ai_gen_id }} ai-cart-button-shop-{{ ai_gen_id }}">
        Shop All Collections
      </a>
    </div>
  {% endif %}
</cart-table-{{ ai_gen_id }}>

<script>
  (function() {
    class CartTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.expiryHours = parseFloat(this.dataset.expiryHours) || 1;
        this.expiryMs = this.expiryHours * 60 * 60 * 1000;
        this.countdownIntervals = [];
      }

      connectedCallback() {
        this.checkExpiredItems();
        this.initializeCountdowns();
        this.setupQuantityButtons();
        this.setupClearCart();
        this.startExpiryCheck();
      }

      disconnectedCallback() {
        this.countdownIntervals.forEach(interval => clearInterval(interval));
        if (this.expiryCheckInterval) {
          clearInterval(this.expiryCheckInterval);
        }
      }

      async checkExpiredItems() {
        const rows = this.querySelectorAll('.ai-cart-row-{{ ai_gen_id }}');
        const expiredLines = [];
        const now = Date.now();

        rows.forEach(row => {
          const addedAt = this.getItemAddedTime(row);
          const timeElapsed = now - addedAt;

          if (timeElapsed >= this.expiryMs) {
            const lineIndex = row.dataset.lineIndex;
            expiredLines.push(lineIndex);
          }
        });

        if (expiredLines.length > 0) {
          await this.removeExpiredItems(expiredLines);
        }
      }

      getItemAddedTime(row) {
        const storageKey = `cart_item_${row.dataset.variantId}`;
        let addedAt = localStorage.getItem(storageKey);

        if (!addedAt) {
          addedAt = Date.now();
          localStorage.setItem(storageKey, addedAt);
        }

        return parseInt(addedAt);
      }

      async removeExpiredItems(lineIndexes) {
        try {
          const updates = {};
          lineIndexes.forEach(line => {
            updates[line] = 0;
          });

          const response = await fetch('/cart/update.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ updates })
          });

          if (response.ok) {
            lineIndexes.forEach(line => {
              const row = this.querySelector(`[data-line-index="${line}"]`);
              if (row) {
                const variantId = row.dataset.variantId;
                localStorage.removeItem(`cart_item_${variantId}`);
              }
            });
            window.location.reload();
          }
        } catch (error) {
          console.error('Error removing expired items:', error);
        }
      }

      initializeCountdowns() {
        const rows = this.querySelectorAll('.ai-cart-row-{{ ai_gen_id }}');

        rows.forEach(row => {
          const countdownElement = row.querySelector('[data-countdown-element]');
          const timeDisplay = countdownElement.querySelector('.countdown-time');
          const addedAt = this.getItemAddedTime(row);

          const updateCountdown = () => {
            const now = Date.now();
            const timeElapsed = now - addedAt;
            const timeRemaining = this.expiryMs - timeElapsed;

            if (timeRemaining <= 0) {
              timeDisplay.textContent = 'Expired';
              countdownElement.classList.add('warning');
              return;
            }

            const minutes = Math.floor(timeRemaining / 60000);
            const seconds = Math.floor((timeRemaining % 60000) / 1000);

            timeDisplay.textContent = `${minutes}m ${seconds}s remaining`;

            if (minutes < 10) {
              countdownElement.classList.add('warning');
            }
          };

          updateCountdown();
          const interval = setInterval(updateCountdown, 1000);
          this.countdownIntervals.push(interval);
        });
      }

      startExpiryCheck() {
        this.expiryCheckInterval = setInterval(() => {
          this.checkExpiredItems();
        }, 30000);
      }

      setupQuantityButtons() {
        const buttons = this.querySelectorAll('.ai-cart-quantity-btn-{{ ai_gen_id }}');

        buttons.forEach(button => {
          button.addEventListener('click', async (e) => {
            const action = button.dataset.action;
            const line = button.dataset.line;
            const input = this.querySelector(`input[data-line="${line}"]`);
            let quantity = parseInt(input.value);

            if (action === 'increase') {
              quantity++;
            } else if (action === 'decrease' && quantity > 1) {
              quantity--;
            }

            await this.updateQuantity(line, quantity);
          });
        });
      }

      async updateQuantity(line, quantity) {
        try {
          const response = await fetch('/cart/change.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              line: line,
              quantity: quantity
            })
          });

          if (response.ok) {
            window.location.reload();
          }
        } catch (error) {
          console.error('Error updating quantity:', error);
        }
      }

      setupClearCart() {
        const clearButton = this.querySelector('[data-clear-cart]');
        if (clearButton) {
          clearButton.addEventListener('click', async () => {
            if (confirm('Are you sure you want to clear your cart?')) {
              await this.clearCart();
            }
          });
        }
      }

      async clearCart() {
        try {
          const response = await fetch('/cart/clear.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          });

          if (response.ok) {
            localStorage.clear();
            window.location.reload();
          }
        } catch (error) {
          console.error('Error clearing cart:', error);
        }
      }
    }

    customElements.define('cart-table-{{ ai_gen_id }}', CartTable{{ ai_gen_id }});
  })();
</script>

