      "default": "#222222"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#eeeeee"
    },
    {
      "type": "color",
      "id": "countdown_color",
      "label": "Countdown color",
      "default": "#e84e4e"
    },
    {
      "type": "color",
      "id": "remove_color",
      "label": "Remove button color",
      "default": "#666666"
    },
    {
      "type": "color",
