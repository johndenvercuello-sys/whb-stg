      "id": "clear_button_hover_bg",
      "label": "Hover background",
      "default": "#e84e4e"
    },
    {
      "type": "color",
      "id": "clear_button_hover_text",
      "label": "Hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Shop button"
    },
    {
      "type": "color",
      "id": "shop_button_bg",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "shop_button_text",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "shop_button_hover_bg",
      "label": "Hover background",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "shop_button_hover_text",
      "label": "Hover text",
      "default": "#ffffff"
