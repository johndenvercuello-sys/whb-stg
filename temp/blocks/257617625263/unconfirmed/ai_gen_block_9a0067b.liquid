{% doc %}
  @prompt
    Overall total of added product in cart, add schema settings. add condition hide  block if cart is empty. block max-width is 1300px, block align center.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% if cart.item_count > 0 %}
  {% style %}
    .ai-cart-total-{{ ai_gen_id }} {
      display: block;
      width: 100%;
      max-width: 1300px;
      margin: 0 auto;
      padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
      background-color: {{ block.settings.background_color }};
      border-radius: {{ block.settings.border_radius }}px;
      text-align: {{ block.settings.text_alignment }};
    }

    .ai-cart-total__wrapper-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: {{ block.settings.spacing }}px;
    }

    .ai-cart-total__label-{{ ai_gen_id }} {
      color: {{ block.settings.label_color }};
      font-size: {{ block.settings.label_size }}px;
      font-weight: {{ block.settings.label_weight }};
      margin: 0;
    }

    .ai-cart-total__amount-{{ ai_gen_id }} {
      color: {{ block.settings.amount_color }};
      font-size: {{ block.settings.amount_size }}px;
      font-weight: {{ block.settings.amount_weight }};
      margin: 0;
    }

    @media screen and (max-width: 749px) {
      .ai-cart-total-{{ ai_gen_id }} {
        padding: {{ block.settings.padding_vertical_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
      }

      .ai-cart-total__label-{{ ai_gen_id }} {
        font-size: {{ block.settings.label_size_mobile }}px;
      }

      .ai-cart-total__amount-{{ ai_gen_id }} {
        font-size: {{ block.settings.amount_size_mobile }}px;
      }
    }
  {% endstyle %}

  <cart-total-{{ ai_gen_id }}
    class="ai-cart-total-{{ ai_gen_id }}"
    {{ block.shopify_attributes }}
  >
    <div class="ai-cart-total__wrapper-{{ ai_gen_id }}">
      {% if block.settings.show_label %}
        <div class="ai-cart-total__label-{{ ai_gen_id }}">
          {{ block.settings.label_text }}
        </div>
      {% endif %}
      <div class="ai-cart-total__amount-{{ ai_gen_id }}">
        {{ cart.total_price | money_with_currency }}
      </div>
    </div>
  </cart-total-{{ ai_gen_id }}>

  <script>
    (function() {
      class CartTotal{{ ai_gen_id }} extends HTMLElement {
        constructor() {
          super();
        }

        connectedCallback() {
          this.updateTotal();
          document.addEventListener('cart:updated', () => this.updateTotal());
        }

        updateTotal() {
          fetch('/cart.js')
            .then(response => response.json())
            .then(cart => {
              const amountElement = this.querySelector('.ai-cart-total__amount-{{ ai_gen_id }}');
              if (amountElement && cart.total_price !== undefined) {
                const formattedPrice = this.formatMoney(cart.total_price);
                amountElement.textContent = formattedPrice;
              }
            });
        }

        formatMoney(cents) {
          const amount = cents / 100;
          return new Intl.NumberFormat('{{ cart.currency.iso_code }}', {
            style: 'currency',
            currency: '{{ cart.currency.iso_code }}'
          }).format(amount);
        }
      }

      customElements.define('cart-total-{{ ai_gen_id }}', CartTotal{{ ai_gen_id }});
    })();
  </script>
{% endif %}

