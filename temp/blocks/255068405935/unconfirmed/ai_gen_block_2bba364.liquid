{% doc %}
  @prompt
    Contact form with Full Name required Field width 100%, Contact No required Field width 50%, Email Add required Field width 50%, Type of Event required select with Cater option, Other option if other option is selected show Other required Input Field, No Pax required Field width 50%, Venue required Field width 50%, Additional Notes Text box 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__heading-{{ ai_gen_id }} {
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-contact-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-form__row-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    width: 100%;
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form__field-{{ ai_gen_id }}.full-width {
    width: 100%;
  }

  .ai-contact-form__field-{{ ai_gen_id }}.half-width {
    width: 50%;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
  }

  .ai-contact-form__label-{{ ai_gen_id }} .required {
    color: {{ block.settings.error_color }};
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__select-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.input_background_color }};
    width: 100%;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__select-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 1px;
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: 16px;
    padding: 12px;
    background-color: rgba(58, 135, 53, 0.1);
    border-radius: 4px;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 8px;
    font-size: 13px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-contact-form__row-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-contact-form__field-{{ ai_gen_id }}.half-width {
      width: 100%;
    }
  }
{% endstyle %}

<event-contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {%- form 'contact' -%}
    <input type="hidden" name="contact[form_type]" value="event_inquiry">
    
    <div class="ai-contact-form__form-{{ ai_gen_id }}">
      <div class="ai-contact-form__field-{{ ai_gen_id }} full-width">
        <label for="contact-name-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          {{ block.settings.full_name_label }} <span class="required">*</span>
        </label>
        <input
          type="text"
          id="contact-name-{{ ai_gen_id }}"
          name="contact[full_name]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          required
          {% if form.errors %}
            aria-invalid="true"
          {% endif %}
        >
      </div>

      <div class="ai-contact-form__row-{{ ai_gen_id }}">
        <div class="ai-contact-form__field-{{ ai_gen_id }} half-width">
          <label for="contact-phone-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.contact_no_label }} <span class="required">*</span>
          </label>
          <input
            type="tel"
            id="contact-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            required
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }} half-width">
          <label for="contact-email-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.email_label }} <span class="required">*</span>
          </label>
          <input
            type="email"
            id="contact-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            required
            autocomplete="email"
          >
        </div>
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }} full-width">
        <label for="event-type-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          {{ block.settings.event_type_label }} <span class="required">*</span>
        </label>
        <select
          id="event-type-{{ ai_gen_id }}"
          name="contact[event_type]"
          class="ai-contact-form__select-{{ ai_gen_id }}"
          required
          data-event-select
        >
          <option value="">Select an option</option>
          <option value="Cater">Cater</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }} full-width" data-other-field style="display: none;">
        <label for="event-other-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          {{ block.settings.other_label }} <span class="required">*</span>
        </label>
        <input
          type="text"
          id="event-other-{{ ai_gen_id }}"
          name="contact[event_other]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          data-other-input
        >
      </div>

      <div class="ai-contact-form__row-{{ ai_gen_id }}">
        <div class="ai-contact-form__field-{{ ai_gen_id }} half-width">
          <label for="no-pax-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.no_pax_label }} <span class="required">*</span>
          </label>
          <input
            type="number"
            id="no-pax-{{ ai_gen_id }}"
            name="contact[no_pax]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            min="1"
            required
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }} half-width">
          <label for="venue-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.venue_label }} <span class="required">*</span>
          </label>
          <input
            type="text"
            id="venue-{{ ai_gen_id }}"
            name="contact[venue]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            required
          >
        </div>
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }} full-width">
        <label for="additional-notes-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          {{ block.settings.additional_notes_label }}
        </label>
        <textarea
          id="additional-notes-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-contact-form__textarea-{{ ai_gen_id }}"
        ></textarea>
      </div>

      <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
        {{ block.settings.submit_button_label }}
      </button>

      {%- if form.posted_successfully? -%}
        <div class="ai-contact-form__success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="ai-contact-form__error-{{ ai_gen_id }}">
          {{ form.errors.messages | first }}
        </div>
      {%- endif -%}
    </div>
  {%- endform -%}
</event-contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class EventContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.eventSelect = this.querySelector('[data-event-select]');
        this.otherField = this.querySelector('[data-other-field]');
        this.otherInput = this.querySelector('[data-other-input]');
        
        if (this.eventSelect) {
          this.eventSelect.addEventListener('change', this.handleEventTypeChange.bind(this));
        }
      }

      handleEventTypeChange(event) {
        const selectedValue = event.target.value;
        
        if (selectedValue === 'Other') {
          this.otherField.style.display = 'flex';
          this.otherInput.setAttribute('required', 'required');
        } else {
          this.otherField.style.display = 'none';
          this.otherInput.removeAttribute('required');
          this.otherInput.value = '';
        }
      }
    }

    customElements.define('event-contact-form-{{ ai_gen_id }}', EventContactForm{{ ai_gen_id }});
  })();
</script>

