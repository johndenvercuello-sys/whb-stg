      "default": "Full Name"
    },
    {
      "type": "text",
      "id": "contact_no_label",
      "label": "Contact number",
      "default": "Contact No"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email address",
      "default": "Email Add"
    },
    {
      "type": "text",
      "id": "event_type_label",
      "label": "Event type",
