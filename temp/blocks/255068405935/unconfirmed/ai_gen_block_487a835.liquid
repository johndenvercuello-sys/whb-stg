{% doc %}
  @prompt
    Contact form with Full Name Field, Contact No Field, Email Add Field, Type of Event select with Cater option, Other option if other option is selected show Other Input Field, No Pax Field, Venue Field, Additional Notes Text box
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-event-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-event-contact-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-event-contact-form__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0 0 {{ block.settings.form_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-event-contact-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-event-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-event-contact-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: 500;
  }

  .ai-event-contact-form__input-{{ ai_gen_id }},
  .ai-event-contact-form__select-{{ ai_gen_id }},
  .ai-event-contact-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    font-size: {{ block.settings.input_text_size }}px;
  }

  .ai-event-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-event-contact-form__select-{{ ai_gen_id }}:focus,
  .ai-event-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border }};
  }

  .ai-event-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-event-contact-form__other-field-{{ ai_gen_id }} {
    display: none;
    margin-top: {{ block.settings.field_spacing }}px;
  }

  .ai-event-contact-form__other-field-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-event-contact-form__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-event-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-event-contact-form__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: {{ block.settings.field_spacing }}px;
    font-size: {{ block.settings.input_text_size }}px;
  }

  .ai-event-contact-form__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: {{ block.settings.field_spacing }}px;
    font-size: {{ block.settings.input_text_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-event-contact-form-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<event-contact-form-{{ ai_gen_id }} class="ai-event-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-event-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.description != blank %}
    <div class="ai-event-contact-form__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
  {% endif %}

  {% form 'contact' %}
    <div class="ai-event-contact-form__form-{{ ai_gen_id }}">
      <div class="ai-event-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-event-contact-form__label-{{ ai_gen_id }}" for="ai-full-name-{{ ai_gen_id }}">
          {{ block.settings.full_name_label }}
        </label>
        <input
          type="text"
          id="ai-full-name-{{ ai_gen_id }}"
          name="contact[full_name]"
          class="ai-event-contact-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.full_name_placeholder }}"
          required
          {% if form.errors %}
            aria-invalid="true"
          {% endif %}
        >
      </div>

      <div class="ai-event-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-event-contact-form__label-{{ ai_gen_id }}" for="ai-contact-no-{{ ai_gen_id }}">
          {{ block.settings.contact_no_label }}
        </label>
        <input
          type="tel"
          id="ai-contact-no-{{ ai_gen_id }}"
          name="contact[phone]"
          class="ai-event-contact-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.contact_no_placeholder }}"
          required
        >
      </div>

      <div class="ai-event-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-event-contact-form__label-{{ ai_gen_id }}" for="ai-email-{{ ai_gen_id }}">
          {{ block.settings.email_label }}
        </label>
        <input
          type="email"
          id="ai-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-event-contact-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.email_placeholder }}"
          required
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="ai-event-contact-form-error-{{ ai_gen_id }}"
          {% endif %}
          {% if form.posted_successfully? %}
            aria-describedby="ai-event-contact-form-success-{{ ai_gen_id }}"
          {% endif %}
        >
      </div>

      <div class="ai-event-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-event-contact-form__label-{{ ai_gen_id }}" for="ai-event-type-{{ ai_gen_id }}">
          {{ block.settings.event_type_label }}
        </label>
        <select
          id="ai-event-type-{{ ai_gen_id }}"
          name="contact[event_type]"
          class="ai-event-contact-form__select-{{ ai_gen_id }}"
          required
          data-other-field="ai-other-event-{{ ai_gen_id }}"
        >
          <option value="">{{ block.settings.event_type_placeholder }}</option>
          <option value="Catering">Catering</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="ai-event-contact-form__field-{{ ai_gen_id }} ai-event-contact-form__other-field-{{ ai_gen_id }}" id="ai-other-event-{{ ai_gen_id }}">
        <label class="ai-event-contact-form__label-{{ ai_gen_id }}" for="ai-other-event-input-{{ ai_gen_id }}">
          {{ block.settings.other_event_label }}
        </label>
        <input
          type="text"
          id="ai-other-event-input-{{ ai_gen_id }}"
          name="contact[other_event_type]"
          class="ai-event-contact-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.other_event_placeholder }}"
        >
      </div>

      <div class="ai-event-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-event-contact-form__label-{{ ai_gen_id }}" for="ai-no-pax-{{ ai_gen_id }}">
          {{ block.settings.no_pax_label }}
        </label>
        <input
          type="number"
          id="ai-no-pax-{{ ai_gen_id }}"
          name="contact[number_of_pax]"
          class="ai-event-contact-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.no_pax_placeholder }}"
          min="1"
          required
        >
      </div>

      <div class="ai-event-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-event-contact-form__label-{{ ai_gen_id }}" for="ai-venue-{{ ai_gen_id }}">
          {{ block.settings.venue_label }}
        </label>
        <input
          type="text"
          id="ai-venue-{{ ai_gen_id }}"
          name="contact[venue]"
          class="ai-event-contact-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.venue_placeholder }}"
          required
        >
      </div>

      <div class="ai-event-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-event-contact-form__label-{{ ai_gen_id }}" for="ai-notes-{{ ai_gen_id }}">
          {{ block.settings.notes_label }}
        </label>
        <textarea
          id="ai-notes-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-event-contact-form__textarea-{{ ai_gen_id }}"
          placeholder="{{ block.settings.notes_placeholder }}"
        ></textarea>
      </div>

      {% if form.errors %}
        <div id="ai-event-contact-form-error-{{ ai_gen_id }}" class="ai-event-contact-form__error-{{ ai_gen_id }}">
          <span>{{ form.errors.messages.email }}</span>
        </div>
      {% endif %}

      {% if form.posted_successfully? %}
        <div id="ai-event-contact-form-success-{{ ai_gen_id }}" class="ai-event-contact-form__success-{{ ai_gen_id }}">
          <span>{{ block.settings.success_message }}</span>
        </div>
      {% endif %}

      <button type="submit" class="ai-event-contact-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {% endform %}
</event-contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class EventContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.eventTypeSelect = this.querySelector('#ai-event-type-{{ ai_gen_id }}');
        this.otherField = this.querySelector('#ai-other-event-{{ ai_gen_id }}');
        this.otherInput = this.querySelector('#ai-other-event-input-{{ ai_gen_id }}');

        if (this.eventTypeSelect && this.otherField && this.otherInput) {
          this.eventTypeSelect.addEventListener('change', this.handleEventTypeChange.bind(this));
        }
      }

      handleEventTypeChange(event) {
        const selectedValue = event.target.value;
        
        if (selectedValue === 'Other') {
          this.otherField.classList.add('active');
          this.otherInput.setAttribute('required', 'required');
        } else {
          this.otherField.classList.remove('active');
          this.otherInput.removeAttribute('required');
          this.otherInput.value = '';
        }
      }
    }

    customElements.define('event-contact-form-{{ ai_gen_id }}', EventContactForm{{ ai_gen_id }});
  })();
</script>

