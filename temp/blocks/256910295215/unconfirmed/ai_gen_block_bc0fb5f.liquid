{% doc %}
  @prompt
    dynamic ajax cart table with Product item "image and title link to item details page, size, gift options, pickup date, pickup day, remove", price, quantity, total price, countdown timer before automatically remove add schema show or hide. use Montserrat font. add clear cart button width 50% and add more products button link to all collections width 50% at the bottom width 50% to left and Proceed to Checkout link to /page/checkout width 50%. add schema desktop width base on theme settings
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap');

  .ai-ajax-cart-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    display: block;
  }

  .ai-ajax-cart-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 20px;
  }

  .ai-ajax-cart-table-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_bg_color }};
    color: {{ block.settings.header_text_color }};
  }

  .ai-ajax-cart-table-{{ ai_gen_id }} th {
    padding: 15px 10px;
    text-align: left;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-ajax-cart-table-{{ ai_gen_id }} td {
    padding: 20px 10px;
    border-bottom: 1px solid {{ block.settings.border_color }};
    vertical-align: middle;
  }

  .ai-ajax-cart-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.row_bg_color }};
    transition: background-color 0.3s ease;
  }

  .ai-ajax-cart-item-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.row_hover_bg_color }};
  }

  .ai-ajax-cart-product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .ai-ajax-cart-product-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-ajax-cart-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-ajax-cart-product-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-ajax-cart-product-title-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 8px;
  }

  .ai-ajax-cart-product-title-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
    text-decoration: none;
  }

  .ai-ajax-cart-product-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-ajax-cart-product-meta-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.meta_text_color }};
    margin-bottom: 4px;
  }

  .ai-ajax-cart-price-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    color: {{ block.settings.price_color }};
  }

  .ai-ajax-cart-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.quantity_border_radius }}px;
    width: fit-content;
  }

  .ai-ajax-cart-quantity-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 8px 12px;
    cursor: pointer;
    font-size: 18px;
    color: {{ block.settings.text_color }};
    transition: background-color 0.3s ease;
  }

  .ai-ajax-cart-quantity-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.row_hover_bg_color }};
  }

  .ai-ajax-cart-quantity-input-{{ ai_gen_id }} {
    width: 50px;
    text-align: center;
    border: none;
    font-weight: 600;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-ajax-cart-total-{{ ai_gen_id }} {
    font-weight: 700;
    font-size: 18px;
    color: {{ block.settings.total_color }};
  }

  .ai-ajax-cart-remove-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    color: {{ block.settings.remove_color }};
    font-size: 20px;
    padding: 5px;
    transition: color 0.3s ease;
  }

  .ai-ajax-cart-remove-{{ ai_gen_id }}:hover {
    color: {{ block.settings.remove_hover_color }};
  }

  .ai-ajax-cart-countdown-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.countdown_color }};
    margin-top: 5px;
    font-weight: 500;
  }

  .ai-ajax-cart-actions-{{ ai_gen_id }} {
    display: flex;
    gap: 0;
    margin-top: 20px;
  }

  .ai-ajax-cart-clear-{{ ai_gen_id }},
  .ai-ajax-cart-continue-{{ ai_gen_id }},
  .ai-ajax-cart-checkout-{{ ai_gen_id }} {
    flex: 1;
    padding: 15px 20px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
    display: inline-block;
    border: none;
  }

  .ai-ajax-cart-clear-{{ ai_gen_id }} {
    background-color: {{ block.settings.clear_btn_bg }};
    color: {{ block.settings.clear_btn_text }};
    border-radius: {{ block.settings.button_border_radius }}px 0 0 {{ block.settings.button_border_radius }}px;
  }

  .ai-ajax-cart-clear-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.clear_btn_hover_bg }};
    color: {{ block.settings.clear_btn_hover_text }};
  }

  .ai-ajax-cart-continue-{{ ai_gen_id }} {
    background-color: {{ block.settings.continue_btn_bg }};
    color: {{ block.settings.continue_btn_text }};
  }

  .ai-ajax-cart-continue-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.continue_btn_hover_bg }};
    color: {{ block.settings.continue_btn_hover_text }};
  }

  .ai-ajax-cart-checkout-{{ ai_gen_id }} {
    background-color: {{ block.settings.checkout_btn_bg }};
    color: {{ block.settings.checkout_btn_text }};
    border-radius: 0 {{ block.settings.button_border_radius }}px {{ block.settings.button_border_radius }}px 0;
  }

  .ai-ajax-cart-checkout-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.checkout_btn_hover_bg }};
    color: {{ block.settings.checkout_btn_hover_text }};
  }

  .ai-ajax-cart-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.meta_text_color }};
    font-size: 16px;
  }

  @media screen and (max-width: 768px) {
    .ai-ajax-cart-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-ajax-cart-table-{{ ai_gen_id }} {
      display: block;
      overflow-x: auto;
    }

    .ai-ajax-cart-table-{{ ai_gen_id }} thead {
      display: none;
    }

    .ai-ajax-cart-table-{{ ai_gen_id }} tbody,
    .ai-ajax-cart-table-{{ ai_gen_id }} tr,
    .ai-ajax-cart-table-{{ ai_gen_id }} td {
      display: block;
      width: 100%;
    }

    .ai-ajax-cart-item-{{ ai_gen_id }} {
      margin-bottom: 20px;
      border: 1px solid {{ block.settings.border_color }};
      border-radius: {{ block.settings.image_border_radius }}px;
      padding: 15px;
    }

    .ai-ajax-cart-table-{{ ai_gen_id }} td {
      border: none;
      padding: 10px 0;
    }

    .ai-ajax-cart-product-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .ai-ajax-cart-actions-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-ajax-cart-clear-{{ ai_gen_id }},
    .ai-ajax-cart-continue-{{ ai_gen_id }},
    .ai-ajax-cart-checkout-{{ ai_gen_id }} {
      width: 100%;
      border-radius: {{ block.settings.button_border_radius }}px;
      margin-bottom: 10px;
    }
  }
{% endstyle %}

<ajax-cart-{{ ai_gen_id }} class="ai-ajax-cart-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ajax-cart-wrapper-{{ ai_gen_id }}">
    <table class="ai-ajax-cart-table-{{ ai_gen_id }}">
      {% if block.settings.show_table_header %}
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
            <th></th>
          </tr>
        </thead>
      {% endif %}
      <tbody class="ai-ajax-cart-items-{{ ai_gen_id }}">
        {% if cart.item_count > 0 %}
          {% for item in cart.items %}
            <tr class="ai-ajax-cart-item-{{ ai_gen_id }}" data-line-index="{{ forloop.index }}" data-variant-id="{{ item.variant_id }}">
              <td>
                <div class="ai-ajax-cart-product-{{ ai_gen_id }}">
                  <div class="ai-ajax-cart-product-image-{{ ai_gen_id }}">
                    {% if item.image %}
                      <a href="{{ item.url }}">
                        <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.image.alt | escape }}" loading="lazy">
                      </a>
                    {% else %}
                      <div style="background-color: #f4f4f4; width: 100%; height: 100%;"></div>
                    {% endif %}
                  </div>
                  <div class="ai-ajax-cart-product-info-{{ ai_gen_id }}">
                    <div class="ai-ajax-cart-product-title-{{ ai_gen_id }}">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </div>
                    {% if item.variant.title != 'Default Title' %}
                      <div class="ai-ajax-cart-product-meta-{{ ai_gen_id }}">
                        <strong>Size:</strong> {{ item.variant.title }}
                      </div>
                    {% endif %}
                    {% for property in item.properties %}
                      {% if property.first == 'Gift Options' %}
                        <div class="ai-ajax-cart-product-meta-{{ ai_gen_id }}">
                          <strong>Gift Options:</strong> {{ property.last }}
                        </div>
                      {% endif %}
                      {% if property.first == 'Pickup Date' %}
                        <div class="ai-ajax-cart-product-meta-{{ ai_gen_id }}">
                          <strong>Pickup Date:</strong> {{ property.last }}
                        </div>
                      {% endif %}
                      {% if property.first == 'Pickup Day' %}
                        <div class="ai-ajax-cart-product-meta-{{ ai_gen_id }}">
                          <strong>Pickup Day:</strong> {{ property.last }}
                        </div>
                      {% endif %}
                    {% endfor %}
                    {% if block.settings.show_countdown %}
                      <div class="ai-ajax-cart-countdown-{{ ai_gen_id }}" data-countdown-minutes="{{ block.settings.countdown_minutes }}">
                        <span class="countdown-text-{{ ai_gen_id }}"></span>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </td>
              <td>
                <div class="ai-ajax-cart-price-{{ ai_gen_id }}">
                  {{ item.price | money }}
                </div>
              </td>
              <td>
                <div class="ai-ajax-cart-quantity-{{ ai_gen_id }}">
                  <button class="ai-ajax-cart-quantity-btn-{{ ai_gen_id }} quantity-decrease" data-line="{{ forloop.index }}" aria-label="Decrease quantity">−</button>
                  <input type="number" class="ai-ajax-cart-quantity-input-{{ ai_gen_id }}" value="{{ item.quantity }}" min="1" data-line="{{ forloop.index }}" readonly>
                  <button class="ai-ajax-cart-quantity-btn-{{ ai_gen_id }} quantity-increase" data-line="{{ forloop.index }}" aria-label="Increase quantity">+</button>
                </div>
              </td>
              <td>
                <div class="ai-ajax-cart-total-{{ ai_gen_id }}">
                  {{ item.line_price | money }}
                </div>
              </td>
              <td>
                <button class="ai-ajax-cart-remove-{{ ai_gen_id }}" data-line="{{ forloop.index }}" aria-label="Remove item">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </button>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="5">
              <div class="ai-ajax-cart-empty-{{ ai_gen_id }}">
                Your cart is empty
              </div>
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>

    {% if cart.item_count > 0 %}
      <div class="ai-ajax-cart-actions-{{ ai_gen_id }}">
        <button class="ai-ajax-cart-clear-{{ ai_gen_id }}" id="clear-cart-{{ ai_gen_id }}">Clear Cart</button>
        <a href="/collections/all" class="ai-ajax-cart-continue-{{ ai_gen_id }}">Add More Products</a>
        <a href="/pages/checkout" class="ai-ajax-cart-checkout-{{ ai_gen_id }}">Proceed to Checkout</a>
      </div>
    {% endif %}
  </div>
</ajax-cart-{{ ai_gen_id }}>

<script>
  (function() {
    class AjaxCart{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.countdownTimers = new Map();
      }

      connectedCallback() {
        this.setupEventListeners();
        if ({{ block.settings.show_countdown | json }}) {
          this.initCountdowns();
        }
      }

      setupEventListeners() {
        this.querySelectorAll('.quantity-increase').forEach(btn => {
          btn.addEventListener('click', (e) => this.updateQuantity(e, 1));
        });

        this.querySelectorAll('.quantity-decrease').forEach(btn => {
          btn.addEventListener('click', (e) => this.updateQuantity(e, -1));
        });

        this.querySelectorAll('.ai-ajax-cart-remove-{{ ai_gen_id }}').forEach(btn => {
          btn.addEventListener('click', (e) => this.removeItem(e));
        });

        const clearBtn = this.querySelector('#clear-cart-{{ ai_gen_id }}');
        if (clearBtn) {
          clearBtn.addEventListener('click', () => this.clearCart());
        }
      }

      async updateQuantity(e, change) {
        const line = e.target.dataset.line;
        const input = this.querySelector(`input[data-line="${line}"]`);
        const newQuantity = parseInt(input.value) + change;

        if (newQuantity < 1) return;

        try {
          const response = await fetch('/cart/change.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              line: line,
              quantity: newQuantity
            })
          });

          if (response.ok) {
            window.location.reload();
          }
        } catch (error) {
          console.error('Error updating quantity:', error);
        }
      }

      async removeItem(e) {
        const line = e.target.closest('button').dataset.line;

        try {
          const response = await fetch('/cart/change.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              line: line,
              quantity: 0
            })
          });

          if (response.ok) {
            window.location.reload();
          }
        } catch (error) {
          console.error('Error removing item:', error);
        }
      }

      async clearCart() {
        if (!confirm('Are you sure you want to clear your cart?')) return;

        try {
          const response = await fetch('/cart/clear.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          });

          if (response.ok) {
            window.location.reload();
          }
        } catch (error) {
          console.error('Error clearing cart:', error);
        }
      }

      initCountdowns() {
        const countdownElements = this.querySelectorAll('.ai-ajax-cart-countdown-{{ ai_gen_id }}');
        
        countdownElements.forEach((element, index) => {
          const minutes = parseInt(element.dataset.countdownMinutes);
          const row = element.closest('.ai-ajax-cart-item-{{ ai_gen_id }}');
          const variantId = row.dataset.variantId;
          const storageKey = `cart_countdown_${variantId}`;
          
          let endTime = localStorage.getItem(storageKey);
          
          if (!endTime) {
            endTime = Date.now() + (minutes * 60 * 1000);
            localStorage.setItem(storageKey, endTime);
          } else {
            endTime = parseInt(endTime);
          }

          const timer = setInterval(() => {
            const now = Date.now();
            const distance = endTime - now;

            if (distance < 0) {
              clearInterval(timer);
              localStorage.removeItem(storageKey);
              this.removeItemByVariantId(variantId, row.dataset.lineIndex);
              return;
            }

            const minutesLeft = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const secondsLeft = Math.floor((distance % (1000 * 60)) / 1000);

            const textElement = element.querySelector('.countdown-text-{{ ai_gen_id }}');
            if (textElement) {
              textElement.textContent = `Auto-remove in ${minutesLeft}m ${secondsLeft}s`;
            }
          }, 1000);

          this.countdownTimers.set(variantId, timer);
        });
      }

      async removeItemByVariantId(variantId, lineIndex) {
        try {
          const response = await fetch('/cart/change.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              line: lineIndex,
              quantity: 0
            })
          });

          if (response.ok) {
            window.location.reload();
          }
        } catch (error) {
          console.error('Error auto-removing item:', error);
        }
      }

      disconnectedCallback() {
        this.countdownTimers.forEach(timer => clearInterval(timer));
        this.countdownTimers.clear();
      }
    }

    customElements.define('ajax-cart-{{ ai_gen_id }}', AjaxCart{{ ai_gen_id }});
  })();
</script>

