{% doc %}
  @prompt
    Dynamic cart table with Product item "image and title link to item details page, size, gift options, pickup date, pickup day", price, quantity, total price. use Montserrat font. add clear cart button and add more products button link to all collections at the bottom. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cart-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    font-family: 'Montserrat', sans-serif;
    display: block;
  }

  .ai-cart-table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    margin-bottom: 20px;
  }

  .ai-cart-table-main-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
  }

  .ai-cart-table-main-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_background }};
  }

  .ai-cart-table-main-{{ ai_gen_id }} th {
    padding: {{ block.settings.cell_padding }}px;
    text-align: left;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    border-bottom: 2px solid {{ block.settings.border_color }};
    font-size: {{ block.settings.header_font_size }}px;
  }

  .ai-cart-table-main-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    border-bottom: 1px solid {{ block.settings.border_color }};
    vertical-align: middle;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_font_size }}px;
  }

  .ai-cart-product-info-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .ai-cart-product-image-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    flex-shrink: 0;
  }

  .ai-cart-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-cart-product-details-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .ai-cart-product-title-{{ ai_gen_id }} {
    font-weight: 600;
    margin: 0;
  }

  .ai-cart-product-title-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
  }

  .ai-cart-product-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: underline;
  }

  .ai-cart-product-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_font_size }}px;
    color: {{ block.settings.meta_text_color }};
  }

  .ai-cart-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    width: fit-content;
  }

  .ai-cart-quantity-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 8px 12px;
    cursor: pointer;
    color: {{ block.settings.text_color }};
    font-size: 18px;
  }

  .ai-cart-quantity-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-cart-quantity-input-{{ ai_gen_id }} {
    width: 50px;
    text-align: center;
    border: none;
    font-size: {{ block.settings.text_font_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-price-{{ ai_gen_id }} {
    font-weight: 600;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-total-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.total_color }};
    font-size: {{ block.settings.total_font_size }}px;
  }

  .ai-cart-remove-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.remove_color }};
    cursor: pointer;
    font-size: 20px;
    padding: 5px;
  }

  .ai-cart-remove-{{ ai_gen_id }}:hover {
    color: {{ block.settings.remove_hover_color }};
  }

  .ai-cart-actions-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    justify-content: flex-end;
    margin-top: 20px;
  }

  .ai-cart-button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 2 }}px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    cursor: pointer;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s ease;
  }

  .ai-cart-clear-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.clear_button_background }};
    color: {{ block.settings.clear_button_text }};
    border: 1px solid {{ block.settings.clear_button_background }};
  }

  .ai-cart-clear-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.clear_button_hover }};
    border-color: {{ block.settings.clear_button_hover }};
  }

  .ai-cart-shop-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.shop_button_background }};
    color: {{ block.settings.shop_button_text }};
  }

  .ai-cart-shop-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.shop_button_hover }};
  }

  .ai-cart-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.meta_text_color }};
  }

  .ai-cart-empty-{{ ai_gen_id }} h2 {
    margin-bottom: 20px;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-cart-table-main-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-cart-table-main-{{ ai_gen_id }} th,
    .ai-cart-table-main-{{ ai_gen_id }} td {
      padding: 10px 5px;
    }

    .ai-cart-product-info-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .ai-cart-product-image-{{ ai_gen_id }} {
      width: 60px;
      height: 60px;
    }

    .ai-cart-actions-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-cart-button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }

    .ai-cart-table-main-{{ ai_gen_id }} th:nth-child(3),
    .ai-cart-table-main-{{ ai_gen_id }} td:nth-child(3) {
      display: none;
    }
  }
{% endstyle %}

<cart-table-{{ ai_gen_id }} class="ai-cart-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if cart.item_count > 0 %}
    <div class="ai-cart-table-wrapper-{{ ai_gen_id }}">
      <table class="ai-cart-table-main-{{ ai_gen_id }}">
        <thead>
          <tr>
            <th>{{ block.settings.product_header }}</th>
            <th>{{ block.settings.price_header }}</th>
            <th>{{ block.settings.quantity_header }}</th>
            <th>{{ block.settings.total_header }}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr data-line-item="{{ forloop.index }}">
              <td>
                <div class="ai-cart-product-info-{{ ai_gen_id }}">
                  <div class="ai-cart-product-image-{{ ai_gen_id }}">
                    <a href="{{ item.url }}">
                      {% if item.image %}
                        <img
                          src="{{ item.image | image_url: width: 200 }}"
                          alt="{{ item.image.alt | escape }}"
                          loading="lazy"
                          width="200"
                          height="200"
                        >
                      {% else %}
                        <div class="ai-cart-image-placeholder-{{ ai_gen_id }}">
                          {{ 'product-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                    </a>
                  </div>
                  <div class="ai-cart-product-details-{{ ai_gen_id }}">
                    <h3 class="ai-cart-product-title-{{ ai_gen_id }}">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </h3>
                    <div class="ai-cart-product-meta-{{ ai_gen_id }}">
                      {% if item.variant.title != 'Default Title' %}
                        <div>{{ block.settings.size_label }}: {{ item.variant.title }}</div>
                      {% endif %}
                      
                      {% if item.properties.size %}
                        <div>{{ block.settings.size_label }}: {{ item.properties.size }}</div>
                      {% endif %}
                      
                      {% if item.properties.gift_options %}
                        <div>{{ block.settings.gift_label }}: {{ item.properties.gift_options }}</div>
                      {% endif %}
                      
                      {% if item.properties.pickup_date %}
                        <div>{{ block.settings.pickup_date_label }}: {{ item.properties.pickup_date }}</div>
                      {% endif %}
                      
                      {% if item.properties.pickup_day %}
                        <div>{{ block.settings.pickup_day_label }}: {{ item.properties.pickup_day }}</div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </td>
              <td>
                <div class="ai-cart-price-{{ ai_gen_id }}">
                  {{ item.price | money }}
                </div>
              </td>
              <td>
                <div class="ai-cart-quantity-{{ ai_gen_id }}">
                  <button
                    class="ai-cart-quantity-btn-{{ ai_gen_id }}"
                    data-action="decrease"
                    data-line="{{ forloop.index }}"
                    aria-label="Decrease quantity"
                  >
                    −
                  </button>
                  <input
                    type="number"
                    class="ai-cart-quantity-input-{{ ai_gen_id }}"
                    value="{{ item.quantity }}"
                    min="0"
                    data-line="{{ forloop.index }}"
                    aria-label="Quantity"
                  >
                  <button
                    class="ai-cart-quantity-btn-{{ ai_gen_id }}"
                    data-action="increase"
                    data-line="{{ forloop.index }}"
                    aria-label="Increase quantity"
                  >
                    +
                  </button>
                </div>
              </td>
              <td>
                <div class="ai-cart-total-{{ ai_gen_id }}">
                  {{ item.line_price | money }}
                </div>
              </td>
              <td>
                <button
                  class="ai-cart-remove-{{ ai_gen_id }}"
                  data-line="{{ forloop.index }}"
                  aria-label="Remove item"
                >
                  ×
                </button>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="ai-cart-actions-{{ ai_gen_id }}">
      <button class="ai-cart-button-{{ ai_gen_id }} ai-cart-clear-btn-{{ ai_gen_id }}" data-action="clear">
        {{ block.settings.clear_cart_text }}
      </button>
      <a href="/collections/all" class="ai-cart-button-{{ ai_gen_id }} ai-cart-shop-btn-{{ ai_gen_id }}">
        {{ block.settings.add_more_text }}
      </a>
    </div>
  {% else %}
    <div class="ai-cart-empty-{{ ai_gen_id }}">
      <h2>{{ block.settings.empty_cart_heading }}</h2>
      <p>{{ block.settings.empty_cart_message }}</p>
      <a href="/collections/all" class="ai-cart-button-{{ ai_gen_id }} ai-cart-shop-btn-{{ ai_gen_id }}" style="margin-top: 20px;">
        {{ block.settings.add_more_text }}
      </a>
    </div>
  {% endif %}
</cart-table-{{ ai_gen_id }}>

<script>
  (function() {
    class CartTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.querySelectorAll('.ai-cart-quantity-btn-{{ ai_gen_id }}').forEach((btn) => {
          btn.addEventListener('click', this.handleQuantityChange.bind(this));
        });

        this.querySelectorAll('.ai-cart-quantity-input-{{ ai_gen_id }}').forEach((input) => {
          input.addEventListener('change', this.handleQuantityInput.bind(this));
        });

        this.querySelectorAll('.ai-cart-remove-{{ ai_gen_id }}').forEach((btn) => {
          btn.addEventListener('click', this.handleRemove.bind(this));
        });

        const clearBtn = this.querySelector('[data-action="clear"]');
        if (clearBtn) {
          clearBtn.addEventListener('click', this.handleClearCart.bind(this));
        }
      }

      handleQuantityChange(event) {
        const button = event.currentTarget;
        const action = button.dataset.action;
        const line = button.dataset.line;
        const input = this.querySelector(`.ai-cart-quantity-input-{{ ai_gen_id }}[data-line="${line}"]`);
        
        let newQuantity = parseInt(input.value);
        
        if (action === 'increase') {
          newQuantity += 1;
        } else if (action === 'decrease') {
          newQuantity = Math.max(0, newQuantity - 1);
        }
        
        this.updateCart(line, newQuantity);
      }

      handleQuantityInput(event) {
        const input = event.currentTarget;
        const line = input.dataset.line;
        const newQuantity = Math.max(0, parseInt(input.value) || 0);
        
        this.updateCart(line, newQuantity);
      }

      handleRemove(event) {
        const button = event.currentTarget;
        const line = button.dataset.line;
        
        this.updateCart(line, 0);
      }

      handleClearCart() {
        if (confirm('Are you sure you want to clear your cart?')) {
          fetch('/cart/clear.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          })
          .then(() => {
            window.location.reload();
          })
          .catch((error) => {
            console.error('Error clearing cart:', error);
          });
        }
      }

      updateCart(line, quantity) {
        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            line: line,
            quantity: quantity
          })
        })
        .then((response) => response.json())
        .then(() => {
          window.location.reload();
        })
        .catch((error) => {
          console.error('Error updating cart:', error);
        });
      }
    }

    customElements.define('cart-table-{{ ai_gen_id }}', CartTable{{ ai_gen_id }});
  })();
</script>

