{% doc %}
  @prompt
    dynamic cart table with Product item "image and title link to item details page, size, gift options, pickup date, pickup day, countdown timer before automatically remove ", price, quantity, total price. use Montserrat font. add clear cart button and add more products button link to all collections at the bottom. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cart-table-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    font-family: 'Montserrat', sans-serif;
    display: block;
  }

  .ai-cart-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    margin-bottom: 30px;
  }

  .ai-cart-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
  }

  .ai-cart-table__table-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_background }};
    color: {{ block.settings.header_text_color }};
  }

  .ai-cart-table__table-{{ ai_gen_id }} th {
    padding: 16px;
    text-align: left;
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-cart-table__table-{{ ai_gen_id }} td {
    padding: 20px 16px;
    border-bottom: 1px solid {{ block.settings.border_color }};
    vertical-align: middle;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-table__product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ai-cart-table__product-image-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
  }

  .ai-cart-table__product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cart-table__product-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-cart-table__product-title-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: {{ block.settings.product_title_size }}px;
    margin-bottom: 8px;
  }

  .ai-cart-table__product-title-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
    text-decoration: none;
  }

  .ai-cart-table__product-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-cart-table__product-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_font_size }}px;
    color: {{ block.settings.meta_text_color }};
    margin-bottom: 4px;
  }

  .ai-cart-table__countdown-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_font_size }}px;
    color: {{ block.settings.countdown_color }};
    font-weight: 600;
    margin-top: 8px;
  }

  .ai-cart-table__price-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-table__quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    width: fit-content;
  }

  .ai-cart-table__quantity-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 8px 12px;
    cursor: pointer;
    font-size: 18px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-table__quantity-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-cart-table__quantity-input-{{ ai_gen_id }} {
    width: 50px;
    text-align: center;
    border: none;
    font-size: 16px;
    font-weight: 600;
  }

  .ai-cart-table__remove-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.remove_color }};
    cursor: pointer;
    font-size: 20px;
    padding: 8px;
  }

  .ai-cart-table__remove-btn-{{ ai_gen_id }}:hover {
    color: {{ block.settings.remove_hover_color }};
  }

  .ai-cart-table__actions-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    justify-content: flex-end;
    margin-top: 20px;
  }

  .ai-cart-table__button-{{ ai_gen_id }} {
    padding: 14px 28px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
  }

  .ai-cart-table__button--clear-{{ ai_gen_id }} {
    background-color: {{ block.settings.clear_button_background }};
    color: {{ block.settings.clear_button_text }};
  }

  .ai-cart-table__button--clear-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.clear_button_hover }};
  }

  .ai-cart-table__button--shop-{{ ai_gen_id }} {
    background-color: {{ block.settings.shop_button_background }};
    color: {{ block.settings.shop_button_text }};
  }

  .ai-cart-table__button--shop-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.shop_button_hover }};
  }

  .ai-cart-table__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.meta_text_color }};
  }

  .ai-cart-table__empty-{{ ai_gen_id }} h3 {
    font-size: 24px;
    margin-bottom: 16px;
  }

  @media screen and (max-width: 768px) {
    .ai-cart-table__table-{{ ai_gen_id }} {
      display: block;
    }

    .ai-cart-table__table-{{ ai_gen_id }} thead {
      display: none;
    }

    .ai-cart-table__table-{{ ai_gen_id }} tbody {
      display: block;
    }

    .ai-cart-table__table-{{ ai_gen_id }} tr {
      display: block;
      margin-bottom: 20px;
      border: 1px solid {{ block.settings.border_color }};
      border-radius: 8px;
      padding: 16px;
    }

    .ai-cart-table__table-{{ ai_gen_id }} td {
      display: block;
      text-align: left;
      padding: 8px 0;
      border: none;
    }

    .ai-cart-table__table-{{ ai_gen_id }} td:before {
      content: attr(data-label);
      font-weight: 600;
      display: block;
      margin-bottom: 4px;
      color: {{ block.settings.header_text_color }};
    }

    .ai-cart-table__actions-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-cart-table__button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

<cart-table-{{ ai_gen_id }} class="ai-cart-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if cart.item_count > 0 %}
    <div class="ai-cart-table__wrapper-{{ ai_gen_id }}">
      <table class="ai-cart-table__table-{{ ai_gen_id }}">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr data-line-item="{{ forloop.index }}" data-variant-id="{{ item.variant_id }}">
              <td data-label="Product">
                <div class="ai-cart-table__product-{{ ai_gen_id }}">
                  <div class="ai-cart-table__product-image-{{ ai_gen_id }}">
                    {% if item.image %}
                      <a href="{{ item.url }}">
                        <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy">
                      </a>
                    {% endif %}
                  </div>
                  <div class="ai-cart-table__product-info-{{ ai_gen_id }}">
                    <div class="ai-cart-table__product-title-{{ ai_gen_id }}">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </div>
                    {% if item.variant.title != 'Default Title' %}
                      <div class="ai-cart-table__product-meta-{{ ai_gen_id }}">
                        Size: {{ item.variant.title }}
                      </div>
                    {% endif %}
                    {% if item.properties.gift_options %}
                      <div class="ai-cart-table__product-meta-{{ ai_gen_id }}">
                        Gift: {{ item.properties.gift_options }}
                      </div>
                    {% endif %}
                    {% if item.properties.pickup_date %}
                      <div class="ai-cart-table__product-meta-{{ ai_gen_id }}">
                        Pickup Date: {{ item.properties.pickup_date }}
                      </div>
                    {% endif %}
                    {% if item.properties.pickup_day %}
                      <div class="ai-cart-table__product-meta-{{ ai_gen_id }}">
                        Pickup Day: {{ item.properties.pickup_day }}
                      </div>
                    {% endif %}
                    {% if block.settings.show_countdown %}
                      <div class="ai-cart-table__countdown-{{ ai_gen_id }}" data-countdown="{{ forloop.index }}">
                        Auto-remove in: <span class="countdown-timer">{{ block.settings.countdown_minutes }}:00</span>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </td>
              <td data-label="Price">
                <div class="ai-cart-table__price-{{ ai_gen_id }}">
                  {{ item.price | money }}
                </div>
              </td>
              <td data-label="Quantity">
                <div class="ai-cart-table__quantity-{{ ai_gen_id }}">
                  <button class="ai-cart-table__quantity-btn-{{ ai_gen_id }}" data-action="decrease" data-line="{{ forloop.index }}">−</button>
                  <input type="number" class="ai-cart-table__quantity-input-{{ ai_gen_id }}" value="{{ item.quantity }}" min="1" data-line="{{ forloop.index }}" readonly>
                  <button class="ai-cart-table__quantity-btn-{{ ai_gen_id }}" data-action="increase" data-line="{{ forloop.index }}">+</button>
                </div>
              </td>
              <td data-label="Total">
                <div class="ai-cart-table__price-{{ ai_gen_id }}">
                  {{ item.line_price | money }}
                </div>
              </td>
              <td data-label="">
                <button class="ai-cart-table__remove-btn-{{ ai_gen_id }}" data-line="{{ forloop.index }}" aria-label="Remove item">
                  ×
                </button>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="ai-cart-table__actions-{{ ai_gen_id }}">
      <button class="ai-cart-table__button-{{ ai_gen_id }} ai-cart-table__button--clear-{{ ai_gen_id }}" id="clear-cart-{{ ai_gen_id }}">
        {{ block.settings.clear_cart_text }}
      </button>
      <a href="/collections/all" class="ai-cart-table__button-{{ ai_gen_id }} ai-cart-table__button--shop-{{ ai_gen_id }}">
        {{ block.settings.add_more_text }}
      </a>
    </div>
  {% else %}
    <div class="ai-cart-table__empty-{{ ai_gen_id }}">
      <h3>Your cart is empty</h3>
      <p>Add some products to get started!</p>
      <a href="/collections/all" class="ai-cart-table__button-{{ ai_gen_id }} ai-cart-table__button--shop-{{ ai_gen_id }}" style="margin-top: 20px;">
        {{ block.settings.add_more_text }}
      </a>
    </div>
  {% endif %}
</cart-table-{{ ai_gen_id }}>

<script>
  (function() {
    class CartTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.countdownIntervals = {};
      }

      connectedCallback() {
        this.setupEventListeners();
        {% if block.settings.show_countdown %}
          this.initCountdowns();
        {% endif %}
      }

      disconnectedCallback() {
        Object.values(this.countdownIntervals).forEach(interval => clearInterval(interval));
      }

      setupEventListeners() {
        const quantityButtons = this.querySelectorAll('.ai-cart-table__quantity-btn-{{ ai_gen_id }}');
        const removeButtons = this.querySelectorAll('.ai-cart-table__remove-btn-{{ ai_gen_id }}');
        const clearButton = this.querySelector('#clear-cart-{{ ai_gen_id }}');

        quantityButtons.forEach(button => {
          button.addEventListener('click', (e) => this.handleQuantityChange(e));
        });

        removeButtons.forEach(button => {
          button.addEventListener('click', (e) => this.handleRemove(e));
        });

        if (clearButton) {
          clearButton.addEventListener('click', () => this.handleClearCart());
        }
      }

      handleQuantityChange(e) {
        const button = e.currentTarget;
        const action = button.dataset.action;
        const line = button.dataset.line;
        const input = this.querySelector(`.ai-cart-table__quantity-input-{{ ai_gen_id }}[data-line="${line}"]`);
        let quantity = parseInt(input.value);

        if (action === 'increase') {
          quantity++;
        } else if (action === 'decrease' && quantity > 1) {
          quantity--;
        }

        this.updateCart(line, quantity);
      }

      handleRemove(e) {
        const line = e.currentTarget.dataset.line;
        this.updateCart(line, 0);
      }

      handleClearCart() {
        if (confirm('Are you sure you want to clear your cart?')) {
          fetch('/cart/clear.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          })
          .then(() => {
            window.location.reload();
          });
        }
      }

      updateCart(line, quantity) {
        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            line: line,
            quantity: quantity
          })
        })
        .then(response => response.json())
        .then(() => {
          window.location.reload();
        })
        .catch(error => {
          console.error('Error updating cart:', error);
        });
      }

      initCountdowns() {
        const countdownElements = this.querySelectorAll('.ai-cart-table__countdown-{{ ai_gen_id }}');
        const countdownMinutes = {{ block.settings.countdown_minutes }};

        countdownElements.forEach((element, index) => {
          const timerSpan = element.querySelector('.countdown-timer');
          const lineItem = element.closest('tr').dataset.lineItem;
          let timeLeft = countdownMinutes * 60;

          this.countdownIntervals[index] = setInterval(() => {
            timeLeft--;

            if (timeLeft <= 0) {
              clearInterval(this.countdownIntervals[index]);
              this.updateCart(lineItem, 0);
              return;
            }

            const minutes = Math.floor(timeLeft / 60);
            const seconds = timeLeft % 60;
            timerSpan.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
          }, 1000);
        });
      }
    }

    customElements.define('cart-table-{{ ai_gen_id }}', CartTable{{ ai_gen_id }});
  })();
</script>

