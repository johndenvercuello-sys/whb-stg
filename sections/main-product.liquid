<script>
  window.addEventListener('load', () => {
    if (typeof Product !== 'undefined') {
      MinimogTheme.Product = new Product();
    }
  });

  document.addEventListener('DOMContentLoaded', function() {
    {% if section.settings.show_gift_card_recipient %}
      const giftForm = document.getElementById('gift-message-form');
      const productForm = document.querySelector('form[data-type="add-to-cart-form"]');
      
      function getSelectedVariantText() {
        const selectEl = document.querySelector('select[name="id"]');
        if (selectEl && selectEl.selectedIndex >= 0) {
          return selectEl.options[selectEl.selectedIndex].text.trim().toLowerCase();
        }
        const checkedRadio = document.querySelector('input[name="id"][type="radio"]:checked');
        if (checkedRadio && checkedRadio.nextElementSibling) {
          return checkedRadio.nextElementSibling.innerText.trim().toLowerCase();
        }
        return '';
      }

      function toggleGiftForm() {
        const selectedText = getSelectedVariantText();
        if (selectedText.includes('gift wrap with message')) {
          giftForm.style.display = 'block';
          giftForm.querySelector('input[name="properties[Recipient Email]"]').required = true;
          giftForm.querySelector('textarea[name="properties[Gift Message]"]').required = true;
        } else {
          giftForm.style.display = 'none';
          giftForm.querySelector('input[name="properties[Recipient Email]"]').required = true;
          giftForm.querySelector('textarea[name="properties[Gift Message]"]').required = true;
        }
      }

      if (productForm) {
        const variantSelect = productForm.querySelector('select[name="id"]');
        if (variantSelect) variantSelect.addEventListener('change', toggleGiftForm);
        productForm.querySelectorAll('input[name="id"][type="radio"]').forEach(radio => {
          radio.addEventListener('change', toggleGiftForm);
        });

        // Initial toggle and interval fallback for some themes
        toggleGiftForm();
        let lastText = '';
        setInterval(() => {
          const newText = getSelectedVariantText();
          if (newText !== lastText) {
            lastText = newText;
            toggleGiftForm();
          }
        }, 500);

        productForm.addEventListener('submit', function() {
          if (giftForm.style.display === 'block') {
            // Remove existing gift-related hidden inputs to avoid duplicates
            productForm.querySelectorAll('input[name^="properties[Recipient"]').forEach(el => el.remove());
            productForm.querySelectorAll('textarea[name="properties[Gift Message]"]').forEach(el => el.remove());

            function cloneField(field, key) {
              const value = field.value.trim();
              if (!value) return;
              const hidden = document.createElement('input');
              hidden.type = 'hidden';
              hidden.name = `properties[${key}]`;
              hidden.value = value;
              productForm.appendChild(hidden);
            }

            cloneField(giftForm.querySelector('input[name="properties[Recipient Email]"]'), 'Recipient Email');
            cloneField(giftForm.querySelector('input[name="properties[Recipient Name]"]'), 'Recipient Name');
            cloneField(giftForm.querySelector('textarea[name="properties[Gift Message]"]'), 'Gift Message');
          }
        });
      }
    {% endif %}
  });
</script>

