{%- comment -%}
  If the current product’s handle is one of the vouchers,
  inject CSS/JS to hide any Flare date‐picker UI.
{%- endcomment -%}
{% if product.handle == 'its-a-bake-day-gift-voucher' or product.handle == 'its-a-bake-day-gift-voucher-2' %}
  <style>
    /* Hide any Flare calendar containers by class/attribute */
    .flare-calendar-wrapper,
    .flare-date-picker,
    .flare-cart-date-picker,
    [data-flare-calendar],
    [data-flare-product-date-picker] {
      display: none !important;
    }
  </style>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Aggressively remove any remaining Flare nodes in the DOM
      function removeFlareNodes() {
        document.querySelectorAll('.flare-calendar-wrapper, .flare-date-picker, .flare-cart-date-picker, [data-flare-calendar], [data-flare-product-date-picker]').forEach(el => el.remove());
        // Also remove anything with “flare” in its class name
        document.querySelectorAll('[class*="flare"]').forEach(el => el.remove());
      }
      // Initial removal
      removeFlareNodes();
      // In case Flare injects late, use a MutationObserver to catch new nodes
      const obs = new MutationObserver(() => removeFlareNodes());
      obs.observe(document.body, { childList: true, subtree: true });
      // Stop observing after 5s (calendar should be gone by then)
      setTimeout(() => obs.disconnect(), 5000);
    });
  </script>
{% endif %}

