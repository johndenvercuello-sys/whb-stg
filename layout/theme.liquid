{% liquid
  assign enable_rtl = settings.enable_rtl
  assign language_support_rtl = settings.language_support_rtl
  if enable_rtl and language_support_rtl != blank
    assign shop_locale = localization.language.iso_code
    assign language_support_rtl_list = language_support_rtl | split: ','
    assign is_rtl = language_support_rtl_list | where: shop_locale
    if is_rtl.size > 0
      assign enable_rtl = true
    else
      assign enable_rtl = false
    endif
  endif

  assign body_classes = 'template-' | append: template.name | append: ' ' | append: template.suffix | append: ' m-gradient m-color-' | append: settings.default_color_scheme

  if settings.page_transition
    assign body_classes = body_classes | append: ' m:overflow-hidden'
  endif

  if template.name == 'index'
    assign body_classes = body_classes | append: ' sf__page-home'
  endif

  if template.name == 'collection'
    assign body_classes = body_classes | append: ' sf__page-collection'
  endif

  if template.suffix == 'about-us'
    assign body_classes = body_classes | append: ' sf__page-about'
  endif
%}

<!doctype html>
<html
  class="no-js {% if settings.page_transition %} m:overflow-hidden{% endif %}"
  lang="{{ request.locale.iso_code }}"
  data-template="{{ template.name }}"
  {% if enable_rtl %}
    dir="rtl"
  {% endif %}
>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1.0, user-scalable=0">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.use_favicon == true and settings.favicon != blank -%}
      <link rel="shortcut icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{- page_title -}}
      {%- if current_tags -%}
        {%- assign meta_tags = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags -}}
      {%- endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
      {%- if template == 'password' -%}
        {{- shop.name -}}
      {%- else -%}
        {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
      {%- endif -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- liquid
      render 'social-meta-tags'
      render 'font-face'
      render 'critical-css'

      echo 'main.css' | asset_url | stylesheet_tag: preload: true

      render 'style-tags'
    -%}

    <script src="{{ 'vendor.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'theme-global.js' | asset_url }}" defer="defer"></script>
    {%- if settings.animations != 'none' -%}
      <script src="{{ 'animations.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}
    {%- if request.design_mode -%}
      <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {{ content_for_header }}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
    {% render 'theme-data' %}
    {% render 'custom-code-head' %}
<style>
  @media only screen and (max-width: 767px) {
    .sf__page-home .m-section-my,
    .sf__page-collection .m-section-my,
    .sf__page-about .m-section-my {
      padding-top: 50px !important;
      padding-bottom: 50px !important;
    }
  }
</style>

{%- render 'foxify-head' -%}</head>


  <body
    id="m-theme"
    class="{{ body_classes }}"
    {% if template.name == 'product' %}
      data-product-id="{{ product.id }}"
    {% endif %}
  >{% sections 'foxify-header-group' %}
    {%- liquid
      render 'page-transition'
      render 'scroll-top-button'
      sections 'header-group'
    -%}

    <main role="main" id="MainContent">
      {{ content_for_layout }}
    </main>

    {%- liquid
      sections 'footer-group'
      render 'script-tags'
      render 'cookie-banner'
      render 'custom-code-body'
    -%}

    <script src="{{ 'product-quick-view.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'wishlist.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'compare-product.js' | asset_url }}" defer="defer"></script>
<session-timer-{{ ai_gen_id }}
  class="ai-session-timer-{{ ai_gen_id }}"
  data-timeout="{{ block.settings.session_timeout }}"
  data-warning-time="{{ block.settings.warning_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.show_warning %}
    <div class="ai-session-timer__container-{{ ai_gen_id }}">
      <div class="ai-session-timer__title-{{ ai_gen_id }}">
        {{ block.settings.warning_title }}
      </div>
      <div class="ai-session-timer__message-{{ ai_gen_id }}">
        {{ block.settings.warning_message }}
      </div>
      <div class="ai-session-timer__countdown-{{ ai_gen_id }}">
        <span class="countdown-seconds">0</span>s
      </div>
    </div>
  {% endif %}
</session-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class SessionTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.timeoutDuration = parseInt(this.dataset.timeout) * 100000;
        this.warningTime = parseInt(this.dataset.warningTime) * 100000;
        this.timeoutId = null;
        this.warningTimeoutId = null;
        this.countdownInterval = null;
        this.warningContainer = this.querySelector('.ai-session-timer__container-{{ ai_gen_id }}');
        this.countdownElement = this.querySelector('.countdown-seconds');
      }

      connectedCallback() {
        this.initSessionTimer();
        this.setupEventListeners();
      }

      disconnectedCallback() {
        this.clearAllTimers();
        this.removeEventListeners();
      }

      initSessionTimer() {
        this.resetTimer();
      }

      setupEventListeners() {
        this.activityEvents = ['mousedown', 'mousemove', 'keypress', 'scroll', 'touchstart', 'click'];
        this.handleActivity = this.handleActivity.bind(this);
        
        this.activityEvents.forEach(event => {
          document.addEventListener(event, this.handleActivity);
        });

        window.addEventListener('storage', (e) => {
          if (e.key === 'cart' || e.key === 'cartUpdated') {
            this.resetTimer();
          }
        });
      }

      removeEventListeners() {
        this.activityEvents.forEach(event => {
          document.removeEventListener(event, this.handleActivity);
        });
      }

      handleActivity() {
        this.resetTimer();
      }

      resetTimer() {
        this.clearAllTimers();
        this.hideWarning();

        this.timeoutId = setTimeout(() => {
          this.expireSession();
        }, this.timeoutDuration);

        const warningDelay = this.timeoutDuration - this.warningTime;
        if (warningDelay > 0 && this.warningContainer) {
          this.warningTimeoutId = setTimeout(() => {
            this.showWarning();
          }, warningDelay);
        }
      }

      showWarning() {
        if (!this.warningContainer) return;

        this.warningContainer.classList.add('visible');
        
        let remainingSeconds = Math.floor(this.warningTime / 1000);
        
        if (this.countdownElement) {
          this.countdownElement.textContent = remainingSeconds;
        }

        this.countdownInterval = setInterval(() => {
          remainingSeconds--;
          if (this.countdownElement) {
            this.countdownElement.textContent = remainingSeconds;
          }
          
          if (remainingSeconds <= 0) {
            clearInterval(this.countdownInterval);
          }
        }, 1000);
      }

      hideWarning() {
        if (this.warningContainer) {
          this.warningContainer.classList.remove('visible');
        }
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
      }

      clearAllTimers() {
        if (this.timeoutId) {
          clearTimeout(this.timeoutId);
        }
        if (this.warningTimeoutId) {
          clearTimeout(this.warningTimeoutId);
        }
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
      }

      async expireSession() {
        try {
          await fetch('/cart/clear.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          });

          if (typeof Shopify !== 'undefined' && Shopify.checkout) {
            Shopify.checkout = null;
          }

          localStorage.removeItem('cart');
          sessionStorage.clear();

          window.location.reload(true);
        } catch (error) {
          console.error('Error clearing cart:', error);
          window.location.reload(true);
        }
      }
    }

    customElements.define('session-timer-{{ ai_gen_id }}', SessionTimer{{ ai_gen_id }});
  })();
</script>
    {%- if settings.enable_predictive_search -%}
      <script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if linklists['gift-wrapping'].links != blank
      and linklists['gift-wrapping'].links.first.type == 'product_link'
    -%}
      <script src="{{ 'gift-wrapping.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if settings.show_swatch_option -%}
      <script src="{{ 'product-card-swatch.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if settings.enable_cart_drawer and template != 'cart' -%}
      {% render 'cart-drawer' %}
    {%- endif -%}
  {%- render 'foxify-footer' -%}{% sections 'foxify-footer-group' %}</body>
</html>
