{% doc %}
  @prompt
    dynamic cart table with Product item "image and title link to item details page, size, gift options, pickup date, pickup day, remove item link, countdown timer before automatically remove add schema show or hide", price, quantity, total price. use Montserrat font. add clear cart button width 50% and add more products button link to all collections width 50% at the bottom width 50% to left and Proceed to Checkout link to /page/checkout width 50%. add schema styling, add schema desktop width base on theme settings, add button to collection/all if cart is empty.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cart-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    font-family: 'Montserrat', sans-serif;
  }

  .ai-cart-table-wrapper-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-cart-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-cart-empty-{{ ai_gen_id }} h2 {
    font-size: 24px;
    margin-bottom: 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-empty-{{ ai_gen_id }} p {
    font-size: 16px;
    margin-bottom: 30px;
    color: {{ block.settings.subtext_color }};
  }

  .ai-cart-table-{{ ai_gen_id }} table {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-cart-table-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_background_color }};
  }

  .ai-cart-table-{{ ai_gen_id }} th {
    padding: {{ block.settings.cell_padding }}px;
    text-align: left;
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-cart-table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    vertical-align: middle;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.body_font_size }}px;
  }

  .ai-cart-table-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-cart-item-product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .ai-cart-item-image-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    flex-shrink: 0;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-cart-item-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cart-item-details-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-cart-item-title-{{ ai_gen_id }} {
    font-weight: 600;
    margin-bottom: 5px;
  }

  .ai-cart-item-title-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
  }

  .ai-cart-item-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
    text-decoration: underline;
  }

  .ai-cart-item-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_font_size }}px;
    color: {{ block.settings.subtext_color }};
    margin-top: 5px;
  }

  .ai-cart-item-meta-{{ ai_gen_id }} div {
    margin-bottom: 3px;
  }

  .ai-cart-countdown-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_font_size }}px;
    color: {{ block.settings.countdown_color }};
    font-weight: 600;
    margin-top: 5px;
  }

  .ai-cart-remove-{{ ai_gen_id }} {
    color: {{ block.settings.remove_color }};
    text-decoration: none;
    font-size: {{ block.settings.remove_font_size }}px;
    cursor: pointer;
    display: inline-block;
    margin-top: 5px;
  }

  .ai-cart-remove-{{ ai_gen_id }}:hover {
    color: {{ block.settings.remove_hover_color }};
    text-decoration: underline;
  }

  .ai-cart-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 120px;
  }

  .ai-cart-quantity-{{ ai_gen_id }} button {
    width: 30px;
    height: 30px;
    border: 1px solid {{ block.settings.border_color }};
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    cursor: pointer;
    border-radius: 4px;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-cart-quantity-{{ ai_gen_id }} button:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-cart-quantity-{{ ai_gen_id }} input {
    width: 50px;
    text-align: center;
    border: 1px solid {{ block.settings.border_color }};
    padding: 5px;
    border-radius: 4px;
  }

  .ai-cart-price-{{ ai_gen_id }} {
    font-weight: 600;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-actions-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    margin-top: 30px;
    justify-content: space-between;
  }

  .ai-cart-actions-left-{{ ai_gen_id }},
  .ai-cart-actions-right-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    width: 50%;
  }

  .ai-cart-button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-weight: 600;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    font-family: 'Montserrat', sans-serif;
    flex: 1;
  }

  .ai-cart-button-clear-{{ ai_gen_id }} {
    background-color: {{ block.settings.clear_button_bg }};
    color: {{ block.settings.clear_button_text_color }};
  }

  .ai-cart-button-clear-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.clear_button_hover_bg }};
    color: {{ block.settings.clear_button_hover_text }};
  }

  .ai-cart-button-shop-{{ ai_gen_id }} {
    background-color: {{ block.settings.shop_button_bg }};
    color: {{ block.settings.shop_button_text_color }};
  }

  .ai-cart-button-shop-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.shop_button_hover_bg }};
    color: {{ block.settings.shop_button_hover_text }};
  }

  .ai-cart-button-checkout-{{ ai_gen_id }} {
    background-color: {{ block.settings.checkout_button_bg }};
    color: {{ block.settings.checkout_button_text_color }};
    width: 100%;
  }

  .ai-cart-button-checkout-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.checkout_button_hover_bg }};
    color: {{ block.settings.checkout_button_hover_text }};
  }

  @media screen and (max-width: 768px) {
    .ai-cart-table-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-cart-table-{{ ai_gen_id }} table {
      display: block;
      overflow-x: auto;
    }

    .ai-cart-actions-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-cart-actions-left-{{ ai_gen_id }},
    .ai-cart-actions-right-{{ ai_gen_id }} {
      width: 100%;
      flex-direction: column;
    }

    .ai-cart-item-product-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }
  }
{% endstyle %}

<cart-table-{{ ai_gen_id }} class="ai-cart-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cart-table-wrapper-{{ ai_gen_id }}">
    {% if cart.item_count == 0 %}
      <div class="ai-cart-empty-{{ ai_gen_id }}">
        <h2>{{ block.settings.empty_cart_heading }}</h2>
        <p>{{ block.settings.empty_cart_message }}</p>
        <a href="/collections/all" class="ai-cart-button-{{ ai_gen_id }} ai-cart-button-shop-{{ ai_gen_id }}">
          {{ block.settings.shop_button_label }}
        </a>
      </div>
    {% else %}
      <table>
        {% if block.settings.show_table_header %}
          <thead>
            <tr>
              <th>{{ block.settings.product_header_text }}</th>
              <th>{{ block.settings.price_header_text }}</th>
              <th>{{ block.settings.quantity_header_text }}</th>
              <th>{{ block.settings.total_header_text }}</th>
            </tr>
          </thead>
        {% endif %}
        <tbody>
          {% for item in cart.items %}
            <tr data-line-item="{{ forloop.index }}" data-variant-id="{{ item.variant_id }}">
              <td>
                <div class="ai-cart-item-product-{{ ai_gen_id }}">
                  <div class="ai-cart-item-image-{{ ai_gen_id }}">
                    <a href="{{ item.url }}">
                      <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" loading="lazy">
                    </a>
                  </div>
                  <div class="ai-cart-item-details-{{ ai_gen_id }}">
                    <div class="ai-cart-item-title-{{ ai_gen_id }}">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </div>
                    <div class="ai-cart-item-meta-{{ ai_gen_id }}">
                      {% if block.settings.show_size and item.variant.title != 'Default Title' %}
                        <div>{{ block.settings.size_label }}: {{ item.variant.title }}</div>
                      {% endif %}
                      {% if block.settings.show_gift_options and item.properties['Gift Message'] %}
                        <div>{{ block.settings.gift_label }}: {{ item.properties['Gift Message'] }}</div>
                      {% endif %}
                      {% if block.settings.show_pickup_date and item.properties['Pickup Date'] %}
                        <div>{{ block.settings.pickup_date_label }}: {{ item.properties['Pickup Date'] }}</div>
                      {% endif %}
                      {% if block.settings.show_pickup_day and item.properties['Pickup Day'] %}
                        <div>{{ block.settings.pickup_day_label }}: {{ item.properties['Pickup Day'] }}</div>
                      {% endif %}
                    </div>
                    {% if block.settings.show_countdown %}
                      <div class="ai-cart-countdown-{{ ai_gen_id }}" data-countdown-minutes="{{ block.settings.countdown_minutes }}">
                        Item will be remove in: <span class="countdown-timer"></span>
                      </div>
                    {% endif %}
                    <a href="#" class="ai-cart-remove-{{ ai_gen_id }}" data-remove-item="{{ forloop.index }}">
                      {{ block.settings.remove_text }}
                    </a>
                  </div>
                </div>
              </td>
              <td>
                <div class="ai-cart-price-{{ ai_gen_id }}">{{ item.price | money }}</div>
              </td>
              <td>
                <div class="ai-cart-quantity-{{ ai_gen_id }}">
                  <button type="button" data-decrease-qty="{{ forloop.index }}">-</button>
                  <input type="number" value="{{ item.quantity }}" min="1" data-qty-input="{{ forloop.index }}" readonly>
                  <button type="button" data-increase-qty="{{ forloop.index }}">+</button>
                </div>
              </td>
              <td>
                <div class="ai-cart-price-{{ ai_gen_id }}">{{ item.line_price | money }}</div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>

      <div class="ai-cart-actions-{{ ai_gen_id }}">
        <div class="ai-cart-actions-left-{{ ai_gen_id }}">
          <button type="button" class="ai-cart-button-{{ ai_gen_id }} ai-cart-button-clear-{{ ai_gen_id }}" data-clear-cart>
            {{ block.settings.clear_button_label }}
          </button>
          <a href="/collections/all" class="ai-cart-button-{{ ai_gen_id }} ai-cart-button-shop-{{ ai_gen_id }}">
            {{ block.settings.shop_button_label }}
          </a>
        </div>
        <div class="ai-cart-actions-right-{{ ai_gen_id }}">
          <a href="/pages/checkout" class="ai-cart-button-{{ ai_gen_id }} ai-cart-button-checkout-{{ ai_gen_id }}">
            {{ block.settings.checkout_button_label }}
          </a>
        </div>
      </div>
    {% endif %}
  </div>
</cart-table-{{ ai_gen_id }}>

<script>
  (function() {
    class CartTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.countdownIntervals = [];
      }

      connectedCallback() {
        this.setupEventListeners();
        this.initCountdowns();
      }

      disconnectedCallback() {
        this.countdownIntervals.forEach(interval => clearInterval(interval));
      }

      setupEventListeners() {
        this.querySelectorAll('[data-remove-item]').forEach(button => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const line = button.getAttribute('data-remove-item');
            this.updateCart(line, 0);
          });
        });

        this.querySelectorAll('[data-decrease-qty]').forEach(button => {
          button.addEventListener('click', () => {
            const line = button.getAttribute('data-decrease-qty');
            const input = this.querySelector(`[data-qty-input="${line}"]`);
            const newQty = Math.max(0, parseInt(input.value) - 1);
            this.updateCart(line, newQty);
          });
        });

        this.querySelectorAll('[data-increase-qty]').forEach(button => {
          button.addEventListener('click', () => {
            const line = button.getAttribute('data-increase-qty');
            const input = this.querySelector(`[data-qty-input="${line}"]`);
            const newQty = parseInt(input.value) + 1;
            this.updateCart(line, newQty);
          });
        });

        const clearButton = this.querySelector('[data-clear-cart]');
        if (clearButton) {
          clearButton.addEventListener('click', () => {
            if (confirm('{{ block.settings.clear_cart_confirm }}')) {
              this.clearCart();
            }
          });
        }
      }

      initCountdowns() {
        const showCountdown = {{ block.settings.show_countdown | json }};
        if (!showCountdown) return;

        this.querySelectorAll('.ai-cart-countdown-{{ ai_gen_id }}').forEach((countdown, index) => {
          const minutes = parseInt(countdown.getAttribute('data-countdown-minutes'));
          const timerElement = countdown.querySelector('.countdown-timer');
          const row = countdown.closest('tr');
          const line = row.getAttribute('data-line-item');

          const storageKey = `cart_countdown_${row.getAttribute('data-variant-id')}`;
          let endTime = localStorage.getItem(storageKey);

          if (!endTime) {
            endTime = Date.now() + (minutes * 60 * 1000);
            localStorage.setItem(storageKey, endTime);
          } else {
            endTime = parseInt(endTime);
          }

          const interval = setInterval(() => {
            const now = Date.now();
            const remaining = endTime - now;

            if (remaining <= 0) {
              clearInterval(interval);
              localStorage.removeItem(storageKey);
              this.updateCart(line, 0);
            } else {
              const mins = Math.floor(remaining / 60000);
              const secs = Math.floor((remaining % 60000) / 1000);
              timerElement.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;
            }
          }, 1000);

          this.countdownIntervals.push(interval);
        });
      }

      updateCart(line, quantity) {
        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            line: line,
            quantity: quantity
          })
        })
        .then(response => response.json())
        .then(() => {
          window.location.reload();
        })
        .catch(error => {
          console.error('Error updating cart:', error);
        });
      }

      clearCart() {
        fetch('/cart/clear.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          }
        })
        .then(response => response.json())
        .then(() => {
          window.location.reload();
        })
        .catch(error => {
          console.error('Error clearing cart:', error);
        });
      }
    }

    customElements.define('cart-table-{{ ai_gen_id }}', CartTable{{ ai_gen_id }});
  })();
</script>

