{% doc %}
  @prompt
    contact form
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.form_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: 500;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 16px;
    font-family: inherit;
  }

  .ai-contact-form__input-{{ ai_gen_id }}::placeholder,
  .ai-contact-form__textarea-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.3s ease;
    {% if block.settings.button_full_width %}
      width: 100%;
    {% else %}
      align-self: {{ block.settings.button_alignment }};
    {% endif %}
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-contact-form__success-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.success_background }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    text-align: center;
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  .ai-contact-form__error-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.error_background }};
    color: {{ block.settings.error_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-form-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding | times: 0.6 }}px;
    }

    .ai-contact-form__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-contact-form__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.subheading != blank %}
    <div class="ai-contact-form__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
  {% endif %}

  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <div class="ai-contact-form__success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
        {{ block.settings.success_message }}
      </div>
    {% endif %}

    {% if form.errors %}
      <div class="ai-contact-form__error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
        <p>{{ 'Please fix the following errors:' }}</p>
        <ul>
          {% for field in form.errors %}
            <li>{{ field | capitalize }} {{ form.errors.messages[field] }}</li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    <div class="ai-contact-form__form-{{ ai_gen_id }}">
      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="ai-contact-name-{{ ai_gen_id }}">
          {{ block.settings.name_label }}{% if block.settings.name_required %} *{% endif %}
        </label>
        <input
          type="text"
          id="ai-contact-name-{{ ai_gen_id }}"
          name="contact[name]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          value="{% if form.name %}{{ form.name }}{% endif %}"
          placeholder="{{ block.settings.name_placeholder }}"
          {% if block.settings.name_required %}required{% endif %}
          autocomplete="name"
        >
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="ai-contact-email-{{ ai_gen_id }}">
          {{ block.settings.email_label }} *
        </label>
        <input
          type="email"
          id="ai-contact-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          value="{% if form.email %}{{ form.email }}{% endif %}"
          placeholder="{{ block.settings.email_placeholder }}"
          required
          autocomplete="email"
          {% if form.errors contains 'email' %}
            aria-invalid="true"
            aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
          {% endif %}
        >
      </div>

      {% if block.settings.show_phone %}
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label class="ai-contact-form__label-{{ ai_gen_id }}" for="ai-contact-phone-{{ ai_gen_id }}">
            {{ block.settings.phone_label }}{% if block.settings.phone_required %} *{% endif %}
          </label>
          <input
            type="tel"
            id="ai-contact-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            value="{% if form.phone %}{{ form.phone }}{% endif %}"
            placeholder="{{ block.settings.phone_placeholder }}"
            {% if block.settings.phone_required %}required{% endif %}
            autocomplete="tel"
          >
        </div>
      {% endif %}

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label class="ai-contact-form__label-{{ ai_gen_id }}" for="ai-contact-message-{{ ai_gen_id }}">
          {{ block.settings.message_label }} *
        </label>
        <textarea
          id="ai-contact-message-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-contact-form__textarea-{{ ai_gen_id }}"
          placeholder="{{ block.settings.message_placeholder }}"
          required
          {% if form.errors contains 'body' %}
            aria-invalid="true"
            aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
          {% endif %}
        >{% if form.body %}{{ form.body }}{% endif %}</textarea>
      </div>

      <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {% endform %}
</div>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Get in touch"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>"
    },
    {
      "type": "inline_richtext",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for contacting us. We'll get back to you as soon as possible."
    },
    {
      "type": "header",
      "content": "Form fields"
    },
    {
      "type": "text",
      "id": "name_label",
      "label": "Name label",
      "default": "Name"
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Name placeholder",
      "default": "Your name"
    },
    {
      "type": "checkbox",
      "id": "name_required",
      "label": "Name required",
      "default": true
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "your@email.com"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone field",
      "default": true
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone label",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone placeholder",
      "default": "Your phone number"
    },
    {
      "type": "checkbox",
      "id": "phone_required",
      "label": "Phone required",
      "default": false
    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Message label",
      "default": "Message"
    },
    {
      "type": "text",
      "id": "message_placeholder",
      "label": "Message placeholder",
      "default": "Write your message here..."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Send message"
    },
    {
      "type": "checkbox",
      "id": "button_full_width",
      "label": "Full width button",
      "default": false
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "Button alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start",
      "info": "Only applies when button is not full width"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Heading spacing",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "form_spacing",
      "label": "Form spacing",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "field_spacing",
