    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label",
      "default": "#222222"
    },
    {
      "type": "header",
      "content": "Input fields"
    },
    {
      "type": "color",
      "id": "input_background",
      "label": "Background",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "input_text_color",
