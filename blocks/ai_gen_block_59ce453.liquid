{% doc %}
  @prompt
    dynamic cart table with Product item "image and title link to item details page, size, gift options, pickup date, pickup day, remove.", price, quantity, total price, countdown timer before automatically remove add schema show or hide. use Montserrat font. add clear cart button width 50% and add more products button link to all collections width 50% at the bottom width 50% to left and Proceed to Checkout link to /page/checkout width 50%. add schema styling, add schema desktop width base on theme settings, add button to collection/all if cart is empty. reload page once the counter timer ends.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap');

  .ai-cart-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    font-family: 'Montserrat', sans-serif;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-cart-table-{{ ai_gen_id }} * {
    font-family: 'Montserrat', sans-serif;
  }

  .ai-cart-table__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
  }

  .ai-cart-table__empty-title-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 400;
    margin-bottom: 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-table__empty-description-{{ ai_gen_id }} {
    font-size: 17px;
    font-weight: 400;
    margin-bottom: 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-table__empty-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 30px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-cart-table__empty-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-cart-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
  }

  .ai-cart-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 30px;
  }

  .ai-cart-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_bg_color }};
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-cart-table__header-{{ ai_gen_id }} th {
    padding: 15px 10px;
    text-align: left;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    font-size: 14px;
    text-transform: uppercase;
  }

  .ai-cart-table__row-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-cart-table__row-{{ ai_gen_id }} td {
    padding: 20px 10px;
    vertical-align: middle;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-table__product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .ai-cart-table__product-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
  }

  .ai-cart-table__product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  .ai-cart-table__product-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-cart-table__product-title-{{ ai_gen_id }} {
    font-weight: 600;
    margin-bottom: 5px;
  }

  .ai-cart-table__product-title-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
    text-decoration: none;
  }

  .ai-cart-table__product-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-cart-table__product-meta-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.subtext_color }};
    margin-top: 5px;
  }

  .ai-cart-table__product-meta-{{ ai_gen_id }} div {
    margin-bottom: 3px;
  }

  .ai-cart-table__price-{{ ai_gen_id }} {
    font-weight: 600;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-table__quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    width: fit-content;
  }

  .ai-cart-table__quantity-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 8px 12px;
    cursor: pointer;
    font-size: 18px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-table__quantity-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.border_color }};
  }

  .ai-cart-table__quantity-input-{{ ai_gen_id }} {
    width: 50px;
    text-align: center;
    border: none;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-table__total-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.price_color }};
    font-size: 16px;
  }

  .ai-cart-table__remove-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.remove_color }};
    cursor: pointer;
    font-size: 20px;
    padding: 5px;
  }

  .ai-cart-table__remove-{{ ai_gen_id }}:hover {
    color: {{ block.settings.remove_hover_color }};
  }

  .ai-cart-table__countdown-{{ ai_gen_id }} {
    {% if block.settings.show_countdown %}
      display: block;
    {% else %}
      display: none;
    {% endif %}
    font-size: 12px;
    color: {{ block.settings.countdown_color }};
    margin-top: 5px;
    font-weight: 500;
  }

  .ai-cart-table__actions-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    margin-bottom: 30px;
  }

  .ai-cart-table__action-btn-{{ ai_gen_id }} {
    flex: 1;
    padding: 15px 20px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 600;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    display: inline-block;
    transition: background-color 0.3s ease;
  }

  .ai-cart-table__clear-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.clear_btn_bg }};
    color: {{ block.settings.clear_btn_text }};
  }

  .ai-cart-table__clear-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.clear_btn_hover_bg }};
  }

  .ai-cart-table__continue-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.continue_btn_bg }};
    color: {{ block.settings.continue_btn_text }};
  }

  .ai-cart-table__continue-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.continue_btn_hover_bg }};
  }

  .ai-cart-table__checkout-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-cart-table__checkout-btn-{{ ai_gen_id }} {
    display: inline-block;
    width: 50%;
    padding: 18px 30px;
    background-color: {{ block.settings.checkout_btn_bg }};
    color: {{ block.settings.checkout_btn_text }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 700;
    font-size: 16px;
    transition: background-color 0.3s ease;
  }

  .ai-cart-table__checkout-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.checkout_btn_hover_bg }};
  }

  @media screen and (max-width: 768px) {
    .ai-cart-table-{{ ai_gen_id }} {
      width: 100%;
      padding: 15px;
    }

    .ai-cart-table__table-{{ ai_gen_id }} {
      display: block;
    }

    .ai-cart-table__header-{{ ai_gen_id }} {
      display: none;
    }

    .ai-cart-table__row-{{ ai_gen_id }} {
      display: block;
      margin-bottom: 20px;
      padding: 15px;
      border: 1px solid {{ block.settings.border_color }};
      border-radius: 8px;
    }

    .ai-cart-table__row-{{ ai_gen_id }} td {
      display: block;
      padding: 10px 0;
      border: none;
    }

    .ai-cart-table__product-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
    }

    .ai-cart-table__actions-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-cart-table__checkout-btn-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<dynamic-cart-table-{{ ai_gen_id }}
  class="ai-cart-table-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-countdown-duration="{{ block.settings.countdown_duration }}"
>
  {% if cart.item_count == 0 %}
    <div class="ai-cart-table__empty-{{ ai_gen_id }}">
      <h3 class="ai-cart-table__empty-title-{{ ai_gen_id }}">Your cart is empty</h3>
      <p class="ai-cart-table__empty-description-{{ ai_gen_id }}">Add some products to get started </p>
      <a href="/collections/all" class="ai-cart-table__empty-button-{{ ai_gen_id }}">
        Add more products
      </a>
    </div>
  {% else %}
    <div class="ai-cart-table__wrapper-{{ ai_gen_id }}">
      <table class="ai-cart-table__table-{{ ai_gen_id }}">
        <thead class="ai-cart-table__header-{{ ai_gen_id }}">
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr class="ai-cart-table__row-{{ ai_gen_id }}" data-line-item="{{ forloop.index }}">
              <td>
                <div class="ai-cart-table__product-{{ ai_gen_id }}">
                  <div class="ai-cart-table__product-image-{{ ai_gen_id }}">
                    <a href="{{ item.url }}">
                      <img
                        src="{{ item.image | image_url: width: 160 }}"
                        alt="{{ item.image.alt | escape }}"
                        loading="lazy"
                      >
                    </a>
                  </div>
                  <div class="ai-cart-table__product-info-{{ ai_gen_id }}">
                    <div class="ai-cart-table__product-title-{{ ai_gen_id }}">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </div>
                    <div class="ai-cart-table__product-meta-{{ ai_gen_id }}">
                      {% if item.variant.title != 'Default Title' %}
                        <div>Size: {{ item.variant.title }}</div>
                      {% endif %}
                      {% for property in item.properties %}
                        {% if property.first == 'Gift Options' %}
                          <div>Gift: {{ property.last }}</div>
                        {% endif %}
                        {% if property.first == 'Pickup Date' %}
                          <div>Pickup Date: {{ property.last }}</div>
                        {% endif %}
                        {% if property.first == 'Pickup Day' %}
                          <div>Pickup Day: {{ property.last }}</div>
                        {% endif %}
                      {% endfor %}
                    </div>
                    {% if block.settings.show_countdown %}
                      <div class="ai-cart-table__countdown-{{ ai_gen_id }}" data-countdown-timer>
                        Removing in <span class="countdown-time">{{ block.settings.countdown_duration }}:00</span>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </td>
              <td>
                <div class="ai-cart-table__price-{{ ai_gen_id }}">
                  {{ item.price | money }}
                </div>
              </td>
              <td>
                <div class="ai-cart-table__quantity-{{ ai_gen_id }}">
                  <button
                    class="ai-cart-table__quantity-btn-{{ ai_gen_id }}"
                    data-action="decrease"
                    data-line="{{ forloop.index }}"
                    aria-label="Decrease quantity"
                  >
                    -
                  </button>
                  <input
                    type="number"
                    class="ai-cart-table__quantity-input-{{ ai_gen_id }}"
                    value="{{ item.quantity }}"
                    min="1"
                    data-line="{{ forloop.index }}"
                    aria-label="Quantity"
                  >
                  <button
                    class="ai-cart-table__quantity-btn-{{ ai_gen_id }}"
                    data-action="increase"
                    data-line="{{ forloop.index }}"
                    aria-label="Increase quantity"
                  >
                    +
                  </button>
                </div>
              </td>
              <td>
                <div class="ai-cart-table__total-{{ ai_gen_id }}">
                  {{ item.line_price | money }}
                </div>
              </td>
              <td>
                <button
                  class="ai-cart-table__remove-{{ ai_gen_id }}"
                  data-action="remove"
                  data-line="{{ forloop.index }}"
                  aria-label="Remove item"
                >
                  ×
                </button>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
<div class="ai-cart-table__actions-{{ ai_gen_id }} m:w-1/2">
    <div class="ai-cart-table__actions-{{ ai_gen_id }} m:w-1/2">
      <button class="ai-cart-table__action-btn-{{ ai_gen_id }} ai-cart-table__clear-btn-{{ ai_gen_id }}" data-action="clear-cart">
        Clear Cart
      </button>
      <a href="/collections/all" class="ai-cart-table__action-btn-{{ ai_gen_id }} ai-cart-table__continue-btn-{{ ai_gen_id }}">
        Add More Products
      </a>
    </div>

    <div class="ai-cart-table__checkout-{{ ai_gen_id }} m:w-1/2">
      <a href="/checkout" class="ai-cart-table__checkout-btn-{{ ai_gen_id }}">
        Proceed to Checkout
      </a>
    </div></div>
  {% endif %}
</dynamic-cart-table-{{ ai_gen_id }}>

<script>
  (function() {
    class DynamicCartTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.countdownDuration = parseInt(this.dataset.countdownDuration) || 10;
        this.countdownTimers = new Map();
      }

      connectedCallback() {
        this.setupEventListeners();
        this.initCountdowns();
      }

      setupEventListeners() {
        this.addEventListener('click', (e) => {
          const target = e.target.closest('button');
          if (!target) return;

          const action = target.dataset.action;
          const line = target.dataset.line;

          if (action === 'increase') {
            this.updateQuantity(line, 1);
          } else if (action === 'decrease') {
            this.updateQuantity(line, -1);
          } else if (action === 'remove') {
            this.removeItem(line);
          } else if (action === 'clear-cart') {
            this.clearCart();
          }
        });

        this.querySelectorAll('.ai-cart-table__quantity-input-{{ ai_gen_id }}').forEach(input => {
          input.addEventListener('change', (e) => {
            const line = e.target.dataset.line;
            const newQty = parseInt(e.target.value);
            if (newQty > 0) {
              this.setQuantity(line, newQty);
            }
          });
        });
      }

      initCountdowns() {
        const rows = this.querySelectorAll('[data-line-item]');
        rows.forEach((row, index) => {
          const countdownEl = row.querySelector('[data-countdown-timer]');
          if (countdownEl) {
            const lineItem = row.dataset.lineItem;
            this.startCountdown(lineItem, countdownEl);
          }
        });
      }

      startCountdown(lineItem, element) {
        let timeLeft = this.countdownDuration * 60;
        const timeDisplay = element.querySelector('.countdown-time');

        const timer = setInterval(() => {
          timeLeft--;
          const minutes = Math.floor(timeLeft / 60);
          const seconds = timeLeft % 60;
          timeDisplay.textContent = minutes + ':' + (seconds < 10 ? '0' : '') + seconds;

          if (timeLeft <= 0) {
            clearInterval(timer);
            this.removeItem(lineItem);
          }
        }, 1000);

        this.countdownTimers.set(lineItem, timer);
      }

      updateQuantity(line, change) {
        const input = this.querySelector(`.ai-cart-table__quantity-input-{{ ai_gen_id }}[data-line="${line}"]`);
        const currentQty = parseInt(input.value);
        const newQty = currentQty + change;

        if (newQty > 0) {
          this.setQuantity(line, newQty);
        }
      }

      setQuantity(line, quantity) {
        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            line: line,
            quantity: quantity
          })
        })
        .then(response => response.json())
        .then(() => {
          window.location.reload();
        })
        .catch(error => {
          console.error('Error updating quantity:', error);
        });
      }

      removeItem(line) {
        const timer = this.countdownTimers.get(line);
        if (timer) {
          clearInterval(timer);
        }

        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            line: line,
            quantity: 0
          })
        })
        .then(response => response.json())
        .then(() => {
          window.location.reload();
        })
        .catch(error => {
          console.error('Error removing item:', error);
        });
      }

      clearCart() {
        if (confirm('Are you sure you want to clear your cart?')) {
          fetch('/cart/clear.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          })
          .then(() => {
            window.location.reload();
          })
          .catch(error => {
            console.error('Error clearing cart:', error);
          });
        }
      }

      disconnectedCallback() {
        this.countdownTimers.forEach(timer => clearInterval(timer));
        this.countdownTimers.clear();
      }
    }

    customElements.define('dynamic-cart-table-{{ ai_gen_id }}', DynamicCartTable{{ ai_gen_id }});
  })();
</script>

