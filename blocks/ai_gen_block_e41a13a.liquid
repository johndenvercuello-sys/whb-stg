{% doc %}
  @prompt
    dynamic cart table with Product item "image and title link to item details page, size, gift options, pickup date, pickup day, countdown timer before automatically remove ", price, quantity, total price. use Montserrat font. add clear cart button and add more products button link to all collections at the bottom. add condition if item is added over 1 minute passed remove item automatically then reload checkout page session.
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap');

  .ai-cart-table-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: 20px;
    display: block;
  }

  .ai-cart-table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    margin-bottom: 20px;
  }

  .ai-cart-table-main-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_bg_color }};
  }

  .ai-cart-table-main-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_bg_color }};
  }

  .ai-cart-table-main-{{ ai_gen_id }} th {
    padding: 15px 10px;
    text-align: left;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    border-bottom: 2px solid {{ block.settings.border_color }};
    font-size: 14px;
  }

  .ai-cart-table-main-{{ ai_gen_id }} td {
    padding: 20px 10px;
    vertical-align: middle;
    border-bottom: 1px solid {{ block.settings.border_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-cart-item-{{ ai_gen_id }} {
    transition: background-color 0.3s ease;
  }

  .ai-cart-item-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.row_hover_color }};
  }

  .ai-cart-product-info-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .ai-cart-product-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .ai-cart-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-cart-product-details-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-cart-product-title-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 5px;
  }

  .ai-cart-product-title-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
    text-decoration: none;
  }

  .ai-cart-product-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-cart-product-meta-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.subtext_color }};
    margin-top: 5px;
  }

  .ai-cart-product-meta-{{ ai_gen_id }} div {
    margin-bottom: 3px;
  }

  .ai-cart-countdown-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: {{ block.settings.countdown_color }};
    font-weight: 600;
    margin-top: 5px;
  }

  .ai-cart-countdown-{{ ai_gen_id }} svg {
    width: 14px;
    height: 14px;
  }

  .ai-cart-price-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: 16px;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 5px;
    width: fit-content;
  }

  .ai-cart-quantity-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 8px 12px;
    cursor: pointer;
    font-size: 18px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-quantity-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.row_hover_color }};
  }

  .ai-cart-quantity-input-{{ ai_gen_id }} {
    width: 50px;
    text-align: center;
    border: none;
    font-weight: 600;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-total-{{ ai_gen_id }} {
    font-weight: 700;
    font-size: 18px;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-actions-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 30px;
    gap: 15px;
  }

  .ai-cart-button-{{ ai_gen_id }} {
    padding: 15px 30px;
    border: none;
    border-radius: 5px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .ai-cart-clear-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.clear_button_bg }};
    color: {{ block.settings.clear_button_text }};
    border: 2px solid {{ block.settings.clear_button_bg }};
  }

  .ai-cart-clear-btn-{{ ai_gen_id }}:hover {
    background-color: transparent;
    color: {{ block.settings.clear_button_bg }};
  }

  .ai-cart-shop-btn-{{ ai_gen_id }} {
    background-color: {{ block.settings.shop_button_bg }};
    color: {{ block.settings.shop_button_text }};
  }

  .ai-cart-shop-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.shop_button_hover_bg }};
  }

  .ai-cart-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.subtext_color }};
  }

  .ai-cart-empty-{{ ai_gen_id }} h3 {
    font-size: 24px;
    margin-bottom: 15px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-empty-{{ ai_gen_id }} p {
    font-size: 16px;
    margin-bottom: 25px;
  }

  @media screen and (max-width: 768px) {
    .ai-cart-table-main-{{ ai_gen_id }} {
      font-size: 12px;
    }

    .ai-cart-table-main-{{ ai_gen_id }} th,
    .ai-cart-table-main-{{ ai_gen_id }} td {
      padding: 10px 5px;
    }

    .ai-cart-product-image-{{ ai_gen_id }} {
      width: 60px;
      height: 60px;
    }

    .ai-cart-product-title-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-cart-actions-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-cart-button-{{ ai_gen_id }} {
      width: 100%;
      text-align: center;
    }
  }
{% endstyle %}

<dynamic-cart-{{ ai_gen_id }}
  class="ai-cart-table-{{ ai_gen_id }}"
  data-timeout="{{ block.settings.auto_remove_minutes }}"
  {{ block.shopify_attributes }}
>
  {% if cart.item_count > 0 %}
    <div class="ai-cart-table-wrapper-{{ ai_gen_id }}">
      <table class="ai-cart-table-main-{{ ai_gen_id }}">
        <thead>
          <tr>
            <th>{{ block.settings.product_header }}</th>
            <th>{{ block.settings.price_header }}</th>
            <th>{{ block.settings.quantity_header }}</th>
            <th>{{ block.settings.total_header }}</th>
          </tr>
        </thead>
        <tbody>
          {% for item in cart.items %}
            <tr
              class="ai-cart-item-{{ ai_gen_id }}"
              data-item-key="{{ item.key }}"
              data-added-at="{{ item.properties['_added_at'] | default: 'now' }}"
            >
              <td>
                <div class="ai-cart-product-info-{{ ai_gen_id }}">
                  <div class="ai-cart-product-image-{{ ai_gen_id }}">
                    {% if item.image %}
                      <img
                        src="{{ item.image | image_url: width: 160 }}"
                        alt="{{ item.title | escape }}"
                        loading="lazy"
                      >
                    {% else %}
                      <div style="background: #f5f5f5; width: 100%; height: 100%;"></div>
                    {% endif %}
                  </div>
                  <div class="ai-cart-product-details-{{ ai_gen_id }}">
                    <div class="ai-cart-product-title-{{ ai_gen_id }}">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </div>
                    <div class="ai-cart-product-meta-{{ ai_gen_id }}">
                      {% if item.variant.title != 'Default Title' %}
                        <div><strong>Size:</strong> {{ item.variant.title }}</div>
                      {% endif %}
                      {% if item.properties['Gift Options'] %}
                        <div><strong>Gift:</strong> {{ item.properties['Gift Options'] }}</div>
                      {% endif %}
                      {% if item.properties['Pickup Date'] %}
                        <div><strong>Pickup Date:</strong> {{ item.properties['Pickup Date'] }}</div>
                      {% endif %}
                      {% if item.properties['Pickup Day'] %}
                        <div><strong>Pickup Day:</strong> {{ item.properties['Pickup Day'] }}</div>
                      {% endif %}
                    </div>
                    <div
                      class="ai-cart-countdown-{{ ai_gen_id }}"
                      data-countdown-for="{{ item.key }}"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"/>
                      </svg>
                      <span class="ai-countdown-time-{{ ai_gen_id }}">{{ block.settings.auto_remove_minutes }}:00</span>
                    </div>
                  </div>
                </div>
              </td>
              <td>
                <div class="ai-cart-price-{{ ai_gen_id }}">{{ item.price | money }}</div>
              </td>
              <td>
                <div class="ai-cart-quantity-{{ ai_gen_id }}">
                  <button
                    class="ai-cart-quantity-btn-{{ ai_gen_id }}"
                    data-action="decrease"
                    data-key="{{ item.key }}"
                    aria-label="Decrease quantity"
                  >
                    -
                  </button>
                  <input
                    type="number"
                    class="ai-cart-quantity-input-{{ ai_gen_id }}"
                    value="{{ item.quantity }}"
                    min="0"
                    data-key="{{ item.key }}"
                    aria-label="Quantity"
                  >
                  <button
                    class="ai-cart-quantity-btn-{{ ai_gen_id }}"
                    data-action="increase"
                    data-key="{{ item.key }}"
                    aria-label="Increase quantity"
                  >
                    +
                  </button>
                </div>
              </td>
              <td>
                <div class="ai-cart-total-{{ ai_gen_id }}">{{ item.line_price | money }}</div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="ai-cart-actions-{{ ai_gen_id }}">
      <button class="ai-cart-button-{{ ai_gen_id }} ai-cart-clear-btn-{{ ai_gen_id }}" data-clear-cart>
        {{ block.settings.clear_cart_text }}
      </button>
      <a href="/collections/all" class="ai-cart-button-{{ ai_gen_id }} ai-cart-shop-btn-{{ ai_gen_id }}">
        {{ block.settings.shop_more_text }}
      </a>
    </div>
  {% else %}
    <div class="ai-cart-empty-{{ ai_gen_id }}">
      <h3>{{ block.settings.empty_cart_heading }}</h3>
      <p>{{ block.settings.empty_cart_message }}</p>
      <a href="/collections/all" class="ai-cart-button-{{ ai_gen_id }} ai-cart-shop-btn-{{ ai_gen_id }}">
        {{ block.settings.shop_more_text }}
      </a>
    </div>
  {% endif %}
</dynamic-cart-{{ ai_gen_id }}>

<script>
  (function() {
    class DynamicCart{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.timeoutMinutes = parseInt(this.dataset.timeout) || 1;
        this.timers = new Map();
      }

      connectedCallback() {
        this.setupEventListeners();
        this.initializeTimers();
        this.checkExpiredItems();
      }

      setupEventListeners() {
        this.querySelectorAll('[data-action="increase"]').forEach(btn => {
          btn.addEventListener('click', (e) => this.updateQuantity(e.target.dataset.key, 1));
        });

        this.querySelectorAll('[data-action="decrease"]').forEach(btn => {
          btn.addEventListener('click', (e) => this.updateQuantity(e.target.dataset.key, -1));
        });

        this.querySelectorAll('.ai-cart-quantity-input-{{ ai_gen_id }}').forEach(input => {
          input.addEventListener('change', (e) => {
            const newQty = parseInt(e.target.value) || 0;
            this.setQuantity(e.target.dataset.key, newQty);
          });
        });

        const clearBtn = this.querySelector('[data-clear-cart]');
        if (clearBtn) {
          clearBtn.addEventListener('click', () => this.clearCart());
        }
      }

      initializeTimers() {
        const items = this.querySelectorAll('.ai-cart-item-{{ ai_gen_id }}');
        items.forEach(item => {
          const key = item.dataset.itemKey;
          const addedAt = this.getItemAddedTime(key);
          const elapsed = Date.now() - addedAt;
          const remaining = (this.timeoutMinutes * 60 * 1000) - elapsed;

          if (remaining > 0) {
            this.startCountdown(key, remaining);
          } else {
            this.removeItem(key);
          }
        });
      }

      getItemAddedTime(key) {
        const stored = localStorage.getItem(`cart_item_${key}`);
        if (stored) {
          return parseInt(stored);
        }
        const now = Date.now();
        localStorage.setItem(`cart_item_${key}`, now.toString());
        return now;
      }

      startCountdown(key, remainingMs) {
        const countdownEl = this.querySelector(`[data-countdown-for="${key}"] .ai-countdown-time-{{ ai_gen_id }}`);
        if (!countdownEl) return;

        const updateCountdown = () => {
          const now = Date.now();
          const addedAt = this.getItemAddedTime(key);
          const elapsed = now - addedAt;
          const remaining = (this.timeoutMinutes * 60 * 1000) - elapsed;

          if (remaining <= 0) {
            this.removeItem(key);
            return;
          }

          const minutes = Math.floor(remaining / 60000);
          const seconds = Math.floor((remaining % 60000) / 1000);
          countdownEl.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
        };

        updateCountdown();
        const timer = setInterval(updateCountdown, 1000);
        this.timers.set(key, timer);
      }

      checkExpiredItems() {
        const items = this.querySelectorAll('.ai-cart-item-{{ ai_gen_id }}');
        items.forEach(item => {
          const key = item.dataset.itemKey;
          const addedAt = this.getItemAddedTime(key);
          const elapsed = Date.now() - addedAt;

          if (elapsed >= this.timeoutMinutes * 60 * 1000) {
            this.removeItem(key);
          }
        });
      }

      async updateQuantity(key, change) {
        const input = this.querySelector(`input[data-key="${key}"]`);
        const currentQty = parseInt(input.value);
        const newQty = Math.max(0, currentQty + change);
        await this.setQuantity(key, newQty);
      }

      async setQuantity(key, quantity) {
        try {
          const response = await fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: key, quantity: quantity })
          });

          if (response.ok) {
            if (quantity === 0) {
              localStorage.removeItem(`cart_item_${key}`);
              const timer = this.timers.get(key);
              if (timer) clearInterval(timer);
            }
            window.location.reload();
          }
        } catch (error) {
          console.error('Error updating cart:', error);
        }
      }

      async removeItem(key) {
        await this.setQuantity(key, 0);
      }

      async clearCart() {
        try {
          const response = await fetch('/cart/clear.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
          });

          if (response.ok) {
            localStorage.clear();
            this.timers.forEach(timer => clearInterval(timer));
            window.location.reload();
          }
        } catch (error) {
          console.error('Error clearing cart:', error);
        }
      }

      disconnectedCallback() {
        this.timers.forEach(timer => clearInterval(timer));
      }
    }

    customElements.define('dynamic-cart-{{ ai_gen_id }}', DynamicCart{{ ai_gen_id }});
  })();
</script>

