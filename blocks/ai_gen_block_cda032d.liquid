{% doc %}
  @prompt
    dynamic ajax cart table with Product item "image and title link to item details page, size, gift options, pickup date, pickup day, remove", price, quantity, total price. use Montserrat font. add clear cart button width 50% and add more products button link to all collections width 50% at the bottom width 50% to left and Proceed to Checkout link to /page/checkout width 50%. add schema desktop width base on theme settings
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ajax-cart-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    font-family: 'Montserrat', sans-serif;
    padding: 20px;
  }

  .ai-cart-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 30px;
  }

  .ai-cart-table-{{ ai_gen_id }} thead {
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-cart-table-{{ ai_gen_id }} th {
    padding: 15px 10px;
    text-align: left;
    font-weight: 600;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
  }

  .ai-cart-table-{{ ai_gen_id }} th:last-child {
    text-align: right;
  }

  .ai-cart-table-{{ ai_gen_id }} tbody tr {
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-cart-table-{{ ai_gen_id }} td {
    padding: 20px 10px;
    vertical-align: middle;
    font-size: {{ block.settings.body_font_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-item-product-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .ai-cart-item-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
  }

  .ai-cart-item-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-cart-item-details-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-cart-item-title-{{ ai_gen_id }} {
    font-weight: 600;
    margin-bottom: 5px;
  }

  .ai-cart-item-title-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
    text-decoration: none;
  }

  .ai-cart-item-title-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-cart-item-meta-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_font_size }}px;
    color: {{ block.settings.subtext_color }};
    margin-top: 5px;
  }

  .ai-cart-item-meta-{{ ai_gen_id }} div {
    margin-bottom: 3px;
  }

  .ai-cart-remove-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    color: {{ block.settings.remove_button_color }};
    cursor: pointer;
    font-size: 14px;
    padding: 5px 10px;
    text-decoration: underline;
  }

  .ai-cart-remove-btn-{{ ai_gen_id }}:hover {
    color: {{ block.settings.remove_button_hover_color }};
  }

  .ai-cart-quantity-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .ai-cart-quantity-btn-{{ ai_gen_id }} {
    width: 30px;
    height: 30px;
    border: 1px solid {{ block.settings.border_color }};
    background: {{ block.settings.quantity_button_bg }};
    color: {{ block.settings.text_color }};
    cursor: pointer;
    border-radius: {{ block.settings.button_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }

  .ai-cart-quantity-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.quantity_button_hover_bg }};
  }

  .ai-cart-quantity-input-{{ ai_gen_id }} {
    width: 50px;
    text-align: center;
    border: 1px solid {{ block.settings.border_color }};
    padding: 5px;
    border-radius: {{ block.settings.button_border_radius }}px;
  }

  .ai-cart-price-{{ ai_gen_id }} {
    font-weight: 600;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-total-price-{{ ai_gen_id }} {
    text-align: right;
    font-weight: 700;
    color: {{ block.settings.price_color }};
  }

  .ai-cart-actions-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-cart-actions-left-{{ ai_gen_id }},
  .ai-cart-actions-right-{{ ai_gen_id }} {
    width: 50%;
    display: flex;
    gap: 10px;
  }

  .ai-cart-actions-right-{{ ai_gen_id }} {
    justify-content: flex-end;
  }

  .ai-cart-clear-btn-{{ ai_gen_id }},
  .ai-cart-continue-btn-{{ ai_gen_id }},
  .ai-cart-checkout-btn-{{ ai_gen_id }} {
    padding: 15px 30px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-weight: 600;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-cart-clear-btn-{{ ai_gen_id }} {
    background: {{ block.settings.clear_button_bg }};
    color: {{ block.settings.clear_button_text }};
    border: 1px solid {{ block.settings.border_color }};
    flex: 1;
  }

  .ai-cart-clear-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.clear_button_hover_bg }};
    color: {{ block.settings.clear_button_hover_text }};
  }

  .ai-cart-continue-btn-{{ ai_gen_id }} {
    background: {{ block.settings.continue_button_bg }};
    color: {{ block.settings.continue_button_text }};
    border: 1px solid {{ block.settings.border_color }};
    flex: 1;
  }

  .ai-cart-continue-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.continue_button_hover_bg }};
    color: {{ block.settings.continue_button_hover_text }};
  }

  .ai-cart-checkout-btn-{{ ai_gen_id }} {
    background: {{ block.settings.checkout_button_bg }};
    color: {{ block.settings.checkout_button_text }};
    flex: 1;
  }

  .ai-cart-checkout-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.checkout_button_hover_bg }};
    color: {{ block.settings.checkout_button_hover_text }};
  }

  .ai-cart-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.subtext_color }};
  }

  .ai-cart-empty-{{ ai_gen_id }} h3 {
    font-size: 24px;
    margin-bottom: 10px;
    color: {{ block.settings.text_color }};
  }

  .ai-cart-loading-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px;
    color: {{ block.settings.subtext_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-cart-table-{{ ai_gen_id }} {
      display: block;
      overflow-x: auto;
    }

    .ai-cart-table-{{ ai_gen_id }} thead {
      display: none;
    }

    .ai-cart-table-{{ ai_gen_id }} tbody,
    .ai-cart-table-{{ ai_gen_id }} tr,
    .ai-cart-table-{{ ai_gen_id }} td {
      display: block;
      width: 100%;
    }

    .ai-cart-table-{{ ai_gen_id }} tr {
      margin-bottom: 20px;
      padding-bottom: 20px;
    }

    .ai-cart-table-{{ ai_gen_id }} td {
      text-align: left;
      padding: 10px 0;
    }

    .ai-cart-table-{{ ai_gen_id }} td:before {
      content: attr(data-label);
      font-weight: 600;
      display: inline-block;
      margin-right: 10px;
    }

    .ai-cart-total-price-{{ ai_gen_id }} {
      text-align: left;
    }

    .ai-cart-actions-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 10px;
    }

    .ai-cart-actions-left-{{ ai_gen_id }},
    .ai-cart-actions-right-{{ ai_gen_id }} {
      width: 100%;
      flex-direction: column;
    }
  }
{% endstyle %}

<ajax-cart-table-{{ ai_gen_id }}
  class="ai-ajax-cart-table-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-cart-loading-{{ ai_gen_id }}" id="ai-cart-loading-{{ ai_gen_id }}">
    Loading cart...
  </div>

  <div id="ai-cart-content-{{ ai_gen_id }}" style="display: none;">
    <table class="ai-cart-table-{{ ai_gen_id }}">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody id="ai-cart-items-{{ ai_gen_id }}">
      </tbody>
    </table>

    <div class="ai-cart-actions-{{ ai_gen_id }}">
      <div class="ai-cart-actions-left-{{ ai_gen_id }}">
        <button
          class="ai-cart-clear-btn-{{ ai_gen_id }}"
          id="ai-cart-clear-{{ ai_gen_id }}"
        >
          Clear cart
        </button>
        <a
          href="/collections/all"
          class="ai-cart-continue-btn-{{ ai_gen_id }}"
        >
          Add more products
        </a>
      </div>
      <div class="ai-cart-actions-right-{{ ai_gen_id }}">
        <a
          href="/pages/checkout"
          class="ai-cart-checkout-btn-{{ ai_gen_id }}"
        >
          Proceed to checkout
        </a>
      </div>
    </div>
  </div>

  <div class="ai-cart-empty-{{ ai_gen_id }}" id="ai-cart-empty-{{ ai_gen_id }}" style="display: none;">
    <h3>Your cart is empty</h3>
    <p>Add some products to get started</p>
  </div>
</ajax-cart-table-{{ ai_gen_id }}>

<script>
  (function() {
    class AjaxCartTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.cartData = null;
      }

      connectedCallback() {
        this.loadCart();
        document.addEventListener('cart:updated', () => this.loadCart());
      }

      async loadCart() {
        try {
          const response = await fetch('/cart.js');
          this.cartData = await response.json();
          this.renderCart();
        } catch (error) {
          console.error('Error loading cart:', error);
        }
      }

      renderCart() {
        const loading = document.getElementById('ai-cart-loading-{{ ai_gen_id }}');
        const content = document.getElementById('ai-cart-content-{{ ai_gen_id }}');
        const empty = document.getElementById('ai-cart-empty-{{ ai_gen_id }}');
        const itemsContainer = document.getElementById('ai-cart-items-{{ ai_gen_id }}');

        loading.style.display = 'none';

        if (this.cartData.items.length === 0) {
          content.style.display = 'none';
          empty.style.display = 'block';
          return;
        }

        empty.style.display = 'none';
        content.style.display = 'block';

        itemsContainer.innerHTML = this.cartData.items.map((item, index) => {
          const itemPrice = this.formatMoney(item.price);
          const itemTotal = this.formatMoney(item.line_price);
          
          const size = item.variant_title && item.variant_title !== 'Default Title' ? item.variant_title : '';
          const giftOptions = item.properties && item.properties['Gift Options'] ? item.properties['Gift Options'] : '';
          const pickupDate = item.properties && item.properties['Pickup Date'] ? item.properties['Pickup Date'] : '';
          const pickupDay = item.properties && item.properties['Pickup Day'] ? item.properties['Pickup Day'] : '';

          return `
            <tr data-line-index="${index + 1}">
              <td data-label="Product">
                <div class="ai-cart-item-product-{{ ai_gen_id }}">
                  <div class="ai-cart-item-image-{{ ai_gen_id }}">
                    <a href="${item.url}">
                      <img src="${item.image}" alt="${item.title}" loading="lazy">
                    </a>
                  </div>
                  <div class="ai-cart-item-details-{{ ai_gen_id }}">
                    <div class="ai-cart-item-title-{{ ai_gen_id }}">
                      <a href="${item.url}">${item.product_title}</a>
                    </div>
                    <div class="ai-cart-item-meta-{{ ai_gen_id }}">
                      ${size ? `<div><strong>Size:</strong> ${size}</div>` : ''}
                      ${giftOptions ? `<div><strong>Gift options:</strong> ${giftOptions}</div>` : ''}
                      ${pickupDate ? `<div><strong>Pickup date:</strong> ${pickupDate}</div>` : ''}
                      ${pickupDay ? `<div><strong>Pickup day:</strong> ${pickupDay}</div>` : ''}
                    </div>
                    <button
                      class="ai-cart-remove-btn-{{ ai_gen_id }}"
                      data-line="${index + 1}"
                      aria-label="Remove ${item.product_title}"
                    >
                      Remove
                    </button>
                  </div>
                </div>
              </td>
              <td data-label="Price">
                <div class="ai-cart-price-{{ ai_gen_id }}">${itemPrice}</div>
              </td>
              <td data-label="Quantity">
                <div class="ai-cart-quantity-{{ ai_gen_id }}">
                  <button
                    class="ai-cart-quantity-btn-{{ ai_gen_id }}"
                    data-line="${index + 1}"
                    data-action="decrease"
                    aria-label="Decrease quantity"
                  >
                    −
                  </button>
                  <input
                    type="number"
                    class="ai-cart-quantity-input-{{ ai_gen_id }}"
                    value="${item.quantity}"
                    min="1"
                    data-line="${index + 1}"
                    aria-label="Quantity"
                  >
                  <button
                    class="ai-cart-quantity-btn-{{ ai_gen_id }}"
                    data-line="${index + 1}"
                    data-action="increase"
                    aria-label="Increase quantity"
                  >
                    +
                  </button>
                </div>
              </td>
              <td data-label="Total">
                <div class="ai-cart-total-price-{{ ai_gen_id }}">${itemTotal}</div>
              </td>
            </tr>
          `;
        }).join('');

        this.attachEventListeners();
      }

      attachEventListeners() {
        const removeButtons = this.querySelectorAll('.ai-cart-remove-btn-{{ ai_gen_id }}');
        removeButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            const line = e.target.dataset.line;
            this.updateCart(line, 0);
          });
        });

        const quantityButtons = this.querySelectorAll('.ai-cart-quantity-btn-{{ ai_gen_id }}');
        quantityButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            const line = e.target.dataset.line;
            const action = e.target.dataset.action;
            const input = this.querySelector(`input[data-line="${line}"]`);
            let quantity = parseInt(input.value);

            if (action === 'increase') {
              quantity++;
            } else if (action === 'decrease' && quantity > 1) {
              quantity--;
            }

            this.updateCart(line, quantity);
          });
        });

        const quantityInputs = this.querySelectorAll('.ai-cart-quantity-input-{{ ai_gen_id }}');
        quantityInputs.forEach(input => {
          input.addEventListener('change', (e) => {
            const line = e.target.dataset.line;
            const quantity = parseInt(e.target.value);
            if (quantity > 0) {
              this.updateCart(line, quantity);
            }
          });
        });

        const clearButton = document.getElementById('ai-cart-clear-{{ ai_gen_id }}');
        if (clearButton) {
          clearButton.addEventListener('click', () => this.clearCart());
        }
      }

      async updateCart(line, quantity) {
        try {
          const response = await fetch('/cart/change.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              line: line,
              quantity: quantity
            })
          });

          this.cartData = await response.json();
          this.renderCart();
          document.dispatchEvent(new CustomEvent('cart:updated'));
        } catch (error) {
          console.error('Error updating cart:', error);
        }
      }

      async clearCart() {
        try {
          const response = await fetch('/cart/clear.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            }
          });

          this.cartData = await response.json();
          this.renderCart();
          document.dispatchEvent(new CustomEvent('cart:updated'));
        } catch (error) {
          console.error('Error clearing cart:', error);
        }
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return '₱' + amount.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
      }
    }

    customElements.define('ajax-cart-table-{{ ai_gen_id }}', AjaxCartTable{{ ai_gen_id }});
  })();
</script>

