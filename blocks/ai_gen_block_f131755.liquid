{% doc %}
  @prompt
    Contact Form, change the form into
    
    Below are required fields:
    Full Name (Last Name, First Name)
    Contact no.
    Email add.
    Type of Event (I.e. Birthday, Wedding, Corporate Function):
    No. of Pax
    Venue/Location:
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 30px;
  }

  .ai-contact-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 10px;
    font-family: 'M-Heading-Font';
  }

  .ai-contact-form__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0;
  }

  .ai-contact-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-contact-form__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  @media (max-width: 767px) {
    .ai-contact-form__row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }

  .ai-contact-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: 14px;
    font-weight: 500;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }},
  .ai-contact-form__select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    font-size: 14px;
    font-family: 'M-Body-Font';
    transition: border-color 0.3s ease;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus,
  .ai-contact-form__select-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_background }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    font-family: 'M-Body-Font';
    cursor: pointer;
    transition: all 0.3s ease;
    {% if block.settings.button_full_width %}
      width: 100%;
    {% else %}
      align-self: {{ block.settings.text_alignment }};
    {% endif %}
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_background }};
  }

  .ai-contact-form__message-{{ ai_gen_id }} {
    padding: 12px 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    margin-top: 20px;
  }

  .ai-contact-form__message--success-{{ ai_gen_id }} {
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }

  .ai-contact-form__message--error-{{ ai_gen_id }} {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  .ai-contact-form__required-{{ ai_gen_id }} {
    color: #da3f3f;
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-form__header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    {% if block.settings.subheading != blank %}
      <p class="ai-contact-form__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
    {% endif %}
  </div>

  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <div class="ai-contact-form__message-{{ ai_gen_id }} ai-contact-form__message--success-{{ ai_gen_id }}" role="status">
        {{ block.settings.success_message }}
      </div>
    {% endif %}

    {% if form.errors %}
      <div class="ai-contact-form__message-{{ ai_gen_id }} ai-contact-form__message--error-{{ ai_gen_id }}" role="alert">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div class="ai-contact-form__form-{{ ai_gen_id }}">
      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label for="contact-fullname-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          Full Name (Last Name, First Name)
          <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
        </label>
        <input
          type="text"
          id="contact-fullname-{{ ai_gen_id }}"
          name="contact[Full Name]"
          class="ai-contact-form__input-{{ ai_gen_id }}"
          placeholder="Dela Cruz, Juan"
          required
        >
      </div>

      <div class="ai-contact-form__row-{{ ai_gen_id }}">
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="contact-phone-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            Contact no.
            <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="tel"
            id="contact-phone-{{ ai_gen_id }}"
            name="contact[Contact Number]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="+63 912 345 6789"
            autocomplete="tel"
            required
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="contact-email-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            Email add.
            <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="email"
            id="contact-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="your@email.com"
            autocomplete="email"
            required
          >
        </div>
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label for="contact-event-type-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          Type of Event
          <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
        </label>
        <select
          id="contact-event-type-{{ ai_gen_id }}"
          name="contact[Type of Event]"
          class="ai-contact-form__select-{{ ai_gen_id }}"
          required
        >
          <option value="">Select event type</option>
          <option value="Birthday">Birthday</option>
          <option value="Wedding">Wedding</option>
          <option value="Corporate Function">Corporate Function</option>
          <option value="Anniversary">Anniversary</option>
          <option value="Baptism">Baptism</option>
          <option value="Graduation">Graduation</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="ai-contact-form__row-{{ ai_gen_id }}">
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="contact-pax-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            No. of Pax
            <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="number"
            id="contact-pax-{{ ai_gen_id }}"
            name="contact[Number of Pax]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="50"
            min="1"
            required
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="contact-venue-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            Venue/Location
            <span class="ai-contact-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="text"
            id="contact-venue-{{ ai_gen_id }}"
            name="contact[Venue/Location]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="Manila, Philippines"
            required
          >
        </div>
      </div>

      <div class="ai-contact-form__field-{{ ai_gen_id }}">
        <label for="contact-message-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
          Additional Notes
        </label>
        <textarea
          id="contact-message-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-contact-form__textarea-{{ ai_gen_id }}"
          placeholder="Any special requests or additional information..."
        ></textarea>
      </div>

      <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {% endform %}
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        const successMessage = this.querySelector('.ai-contact-form__message--success-{{ ai_gen_id }}');
        
        if (successMessage) {
          form.reset();
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Event Inquiry Form"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fill out the form below and we'll get back to you soon"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for your inquiry! We'll contact you shortly to discuss your event."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
