{% doc %}
  @prompt
    check if no product item is added on cart then prompt a message and redirect to home page in 10 seconds
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-empty-cart-redirect-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 40px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-empty-cart-redirect__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 20px;
    color: {{ block.settings.icon_color }};
  }

  .ai-empty-cart-redirect__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-empty-cart-redirect__message-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.message_size }}px;
    margin: 0 0 20px;
    opacity: 0.8;
  }

  .ai-empty-cart-redirect__countdown-{{ ai_gen_id }} {
    color: {{ block.settings.countdown_color }};
    font-size: {{ block.settings.countdown_size }}px;
    font-weight: 600;
    margin: 0;
  }

  .ai-empty-cart-redirect__hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-empty-cart-redirect-{{ ai_gen_id }} {
      padding: 30px 20px;
    }

    .ai-empty-cart-redirect__icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.8);
      height: calc({{ block.settings.icon_size }}px * 0.8);
    }

    .ai-empty-cart-redirect__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-empty-cart-redirect__message-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.message_size }}px * 0.9);
    }
  }
{% endstyle %}

<empty-cart-redirect-{{ ai_gen_id }}
  class="ai-empty-cart-redirect-{{ ai_gen_id }} {% if cart.item_count > 0 %}ai-empty-cart-redirect__hidden-{{ ai_gen_id }}{% endif %}"
  data-redirect-url="{{ block.settings.redirect_url | default: routes.root_url }}"
  data-countdown-seconds="{{ block.settings.countdown_seconds }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-empty-cart-redirect__icon-{{ ai_gen_id }}">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
    </svg>
  </div>

  <h2 class="ai-empty-cart-redirect__heading-{{ ai_gen_id }}">
    {{ block.settings.heading }}
  </h2>

  <div class="ai-empty-cart-redirect__message-{{ ai_gen_id }}">
    {{ block.settings.message }}
  </div>

  <p class="ai-empty-cart-redirect__countdown-{{ ai_gen_id }}">
    {{ block.settings.countdown_text }} <span class="ai-countdown-number-{{ ai_gen_id }}">{{ block.settings.countdown_seconds }}</span> {{ block.settings.countdown_suffix }}
  </p>
</empty-cart-redirect-{{ ai_gen_id }}>

<script>
  (function() {
    class EmptyCartRedirect{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.redirectUrl = this.dataset.redirectUrl;
        this.countdownSeconds = parseInt(this.dataset.countdownSeconds);
        this.countdownElement = this.querySelector('.ai-countdown-number-{{ ai_gen_id }}');
        this.currentCount = this.countdownSeconds;
        this.intervalId = null;
      }

      connectedCallback() {
        this.startCountdown();
      }

      startCountdown() {
        this.intervalId = setInterval(() => {
          this.currentCount--;
          
          if (this.countdownElement) {
            this.countdownElement.textContent = this.currentCount;
          }

          if (this.currentCount <= 0) {
            clearInterval(this.intervalId);
            window.location.href = this.redirectUrl;
          }
        }, 10);
      }

      disconnectedCallback() {
        if (this.intervalId) {
          clearInterval(this.intervalId);
        }
      }
    }

    customElements.define('empty-cart-redirect-{{ ai_gen_id }}', EmptyCartRedirect{{ ai_gen_id }});
  })();
</script>

